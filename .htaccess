

# Without these, big phone-camera uploads overflow PHP's default 8M cap and
# the entire POST body (csrf_token included) is silently discarded.
<IfModule mod_php.c>
    php_value upload_max_filesize 8M
    php_value post_max_size      16M
</IfModule>

RewriteEngine On

# Block dotfiles and sensitive files
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "(composer\.(json|lock)|package(-lock)?\.json|README\.md|LICENSE|\.log)$">
    Require all denied
</FilesMatch>

# Block direct access to app folders
RedirectMatch 404 ^/(src|templates|var|vendor)(/|$)

# Front-controller routing
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]
