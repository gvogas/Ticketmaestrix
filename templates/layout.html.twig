<!DOCTYPE html>
<html lang="{{ current_locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ trans('app.title') }}{% endblock %}</title>
    <link rel="icon" type="image/png" href="{{ base_path }}/assets/img/ticketmaestrix-logo.png">
    <link rel="apple-touch-icon" href="{{ base_path }}/assets/img/ticketmaestrix-logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="{{ base_path }}/css/site.css">
    <link rel="stylesheet" href="{{ base_path }}/css/forms.css">
    {% block head %}{% endblock %}
</head>

<body class="d-flex flex-column min-vh-100">

    <div id="tm-loading-bar" class="tm-loading-bar" aria-hidden="true"></div>

    {% block navbar %}
        {% include 'partials/navbar.html.twig' %}
    {% endblock %}

    <main class="flex-grow-1 pb-5">
        {% include 'partials/flash.html.twig' %}
        {% block content %}{% endblock %}
    </main>

    {% block footer %}
    <footer class="text-center py-4" style="background: linear-gradient(135deg, #371840 0%, #5E246E 100%); color: rgba(255,255,255,0.6); border-top: 1px solid rgba(255,255,255,0.08);">
        <div class="container">
            <p class="mb-0 small">&copy; 2026 {{ trans('app.title') }}. {{ trans('footer.rights') }}</p>
        </div>
    </footer>
    {% endblock %}

    {% include 'partials/confirm-modal.html.twig' %}

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
    (function () {
        var bar = document.getElementById('tm-loading-bar');
        if (!bar) return;

        function startLoading(target) {
            bar.classList.remove('is-done');
            // Force reflow so the transition restarts even if start is called twice.
            void bar.offsetWidth;
            bar.classList.add('is-active');
            if (target) target.classList.add('is-loading');
        }

        document.addEventListener('click', function (e) {
         
            if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button !== 0) return;
            var link = e.target.closest('.pagination .page-link');
            if (!link) return;
            // Disabled and active links don't actually navigate.
            var item = link.closest('.page-item');
            if (item && (item.classList.contains('disabled') || item.classList.contains('active'))) return;
            startLoading(link);
        }, true);

        
        window.addEventListener('pageshow', function (e) {
            if (e.persisted) {
                bar.classList.remove('is-active', 'is-done');
                document.querySelectorAll('.page-link.is-loading').forEach(function (el) {
                    el.classList.remove('is-loading');
                });
            }
        });
    })();

    (function () {
        var modalEl = document.getElementById('tmConfirmModal');
        var bodyEl  = document.getElementById('tmConfirmModalBody');
        var okBtn   = document.getElementById('tmConfirmModalOk');
        if (!modalEl || !bodyEl || !okBtn || !window.bootstrap) return;

        var modal = new bootstrap.Modal(modalEl);
        var pendingForm = null;

        document.addEventListener('submit', function (e) {
            var form = e.target;
            if (!(form instanceof HTMLFormElement)) return;
            var msg = form.getAttribute('data-confirm');
            if (!msg) return;
            if (form.dataset.confirmed === '1') return;
            e.preventDefault();
            bodyEl.textContent = msg;
            pendingForm = form;
            modal.show();
        }, true);

        okBtn.addEventListener('click', function () {
            if (!pendingForm) { modal.hide(); return; }
            var form = pendingForm;
            pendingForm = null;
            form.dataset.confirmed = '1';
            modal.hide();
            form.submit();
        });

        modalEl.addEventListener('hidden.bs.modal', function () {
            if (pendingForm) {
                delete pendingForm.dataset.confirmed;
                pendingForm = null;
            }
        });
    })();
    </script>
    {% block scripts %}{% endblock %}
</body>
</html>
