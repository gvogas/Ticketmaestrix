{% extends "layout.html.twig" %}
{% block title %}{{ trans('app.title') }} - #{{ ticket.id }}{% endblock %}
{% block head %}
<style>

    body {
        background-color: #f8fafc;
        color: #1a202c;
    }

    /* Ticket Card Aesthetic */
    .ticket-container {
        max-width: 550px;
        margin: 4rem auto;
    }

    .ticket-card {
        background: white;
        border-radius: 24px;
        border: 1px solid var(--border-color);
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

    /* The Purple "Stub" Edge */
    .ticket-card::before {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 12px;
        background: var(--brand-purple);
    }

    .ticket-header {
        background: #fafafa;
        padding: 2rem;
        border-bottom: 2px dashed #e2e8f0;
        position: relative;
    }

    /* Decorative "Punch Holes" for the ticket look */
    .ticket-header::after, .ticket-header::before {
        content: '';
        position: absolute;
        bottom: -12px;
        width: 24px;
        height: 24px;
        background: #f8fafc; /* Matches body bg */
        border-radius: 50%;
        border: 1px solid var(--border-color);
    }
    .ticket-header::before { left: -13px; }
    .ticket-header::after { right: -13px; }

    .price-pill {
        background: var(--brand-purple);
        color: white;
        font-weight: 800;
        padding: 8px 20px;
        border-radius: 50px;
        font-size: 1.1rem;
    }

    .info-label {
        text-transform: uppercase;
        font-size: 0.75rem;
        font-weight: 700;
        color: #94a3b8;
        letter-spacing: 0.05em;
        display: block;
        margin-bottom: 2px;
    }

    .info-value {
        font-size: 1.25rem;
        font-weight: 600;
        color: #1e293b;
    }

    .btn-purple-outline {
        color: var(--brand-purple);
        border: 2px solid var(--brand-purple);
        font-weight: 700;
        border-radius: 10px;
        padding: 10px 20px;
        transition: all 0.3s;
    }

    .btn-purple-outline:hover {
        background: var(--brand-purple);
        color: white;
    }

    .back-link {
        color: #64748b;
        font-weight: 600;
        transition: color 0.2s;
    }
    .back-link:hover { color: var(--brand-purple); }
</style>
{% endblock %}
{% block content %}

    <div class="container">
        <div class="ticket-container">

            <a href="{{ base_path }}/tickets" class="back-link text-decoration-none d-inline-flex align-items-center mb-4">
                <i class="bi bi-arrow-left-short fs-4"></i> {{ trans('tadmin.back_inv') }}
            </a>

            <div class="ticket-card">
                
                <div class="ticket-header d-flex justify-content-between align-items-center">
                    <div>
                        <span class="info-label">{{ trans('tadmin.detail_ref') }}</span>
                        <h2 class="h4 fw-800 mb-0">#{{ ticket.id }}</h2>
                    </div>
                    <div class="price-pill">
                        ${{ ticket.price }}
                    </div>
                </div>

                <div class="p-4 ps-5">
                    <div class="row g-4">
                        <div class="col-12">
                            <span class="info-label">{{ trans('tadmin.detail_event') }}</span>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-calendar-event me-2 text-muted"></i>
                                <span class="fw-bold">{{ event ? event.title : ('Event #' ~ ticket.event_id) }}</span>
                            </div>
                        </div>

                        <div class="col-6">
                            <span class="info-label">{{ trans('tadmin.row_label') }}</span>
                            <div class="info-value">
                                <i class="bi bi-grid-3x2 me-2 text-muted fs-6"></i>{{ ticket.row ?: 'N/A' }}
                            </div>
                        </div>

                        <div class="col-6">
                            <span class="info-label">{{ trans('tadmin.detail_seat_no') }}</span>
                            <div class="info-value">
                                <i class="bi bi-person-badge me-2 text-muted fs-6"></i>{{ ticket.seat ?: 'N/A' }}
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 pt-4 border-top d-flex gap-2">
                        <a href="{{ base_path }}/tickets/{{ ticket.id }}/edit" class="btn btn-purple-outline flex-grow-1">
                            <i class="bi bi-pencil-square me-2"></i> {{ trans('tadmin.detail_edit') }}
                        </a>

                        <button type="button" class="btn btn-outline-danger px-4 py-2 fw-bold" style="border-radius: 10px; border-width: 2px;"
                                data-bs-toggle="modal" data-bs-target="#deleteTicketDetailModal">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </div>
                </div>
            </div>

            <p class="text-center text-muted small mt-4">
                <i class="bi bi-shield-check me-1"></i> {{ trans('tadmin.detail_footer') }}
            </p>
        </div>
    </div>

    <div class="modal fade" id="deleteTicketDetailModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow">
                <div class="modal-header border-0 pt-4 px-4">
                    <h5 class="fw-bold text-danger">{{ trans('tadmin.crud.delete') }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body px-4 pb-4">
                    <p class="mb-0">{{ trans('confirm.delete_ticket') }}</p>
                </div>
                <div class="modal-footer border-0 pb-4 px-4">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">{{ trans('tadmin.crud.cancel') }}</button>
                    <form action="{{ base_path }}/tickets/{{ ticket.id }}/delete" method="POST" class="m-0">
                        {{ csrf_field() }}
                        <button type="submit" class="btn btn-danger px-4">{{ trans('tadmin.crud.delete') }}</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
