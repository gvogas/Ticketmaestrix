<!DOCTYPE html>
<html lang="{{ current_locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ trans('evtickets.tickets') }} - {{ trans('app.title') }}</title>

    <!-- Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');

        :root {
            --brand-purple: #5E246E;
            --brand-deep: #371840;
            --brand-hover: #4a1d56;
            --bg-light: #f8fafc;
            --border-color: #e2e8f0;
        }

        /* 1. Reset & Global Styles */
        * { border-radius: 0 !important; }

        body {
            background-color: var(--bg-light);
            font-family: 'Inter', sans-serif;
            color: #1a202c;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        main { flex: 1; }

        /* 2. Header Section */
        .admin-header {
            background: white;
            padding: 3rem 0;
            border-bottom: 2px solid var(--brand-purple);
            margin-bottom: 3rem;
        }

        .btn-mgmt {
            background: white;
            border: 2px solid var(--brand-deep);
            color: var(--brand-deep);
            font-weight: 700;
            padding: 10px 20px;
            text-transform: uppercase;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            transition: all 0.2s;
        }

        .btn-mgmt:hover {
            background: var(--brand-deep);
            color: white;
        }

        /* 3. Ticket Card Design */
        .ticket-card {
            border: 2px solid var(--brand-deep);
            background: white;
            transition: all 0.3s ease;
            height: 100%;
            display: flex;
            flex-direction: column;
            box-shadow: 8px 8px 0px rgba(55, 24, 64, 0.1);
        }

        .ticket-card:hover {
            transform: translate(-4px, -4px);
            box-shadow: 12px 12px 0px rgba(55, 24, 64, 0.15);
        }

        .ticket-visual {
            background: var(--brand-purple);
            height: 120px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            border-bottom: 2px dashed white;
        }

        .ticket-icon {
            color: rgba(255,255,255,0.2) !important;
            font-size: 5rem;
            position: absolute;
        }

        .price-badge {
            position: relative;
            z-index: 2;
            background: #ffffff;
            color: var(--brand-purple);
            font-weight: 800;
            padding: 8px 16px;
            font-size: 1.2rem;
            border: 2px solid var(--brand-deep);
        }

        .card-content {
            padding: 1.5rem;
            flex-grow: 1;
            text-align: center;
        }

        .card-footer {
            padding: 1rem;
            background: white;
            border-top: 1px solid #eee;
        }

        .btn-add-cart {
            background-color: var(--brand-purple);
            color: white;
            border: none;
            padding: 12px;
            width: 100%;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: background 0.2s;
        }

        .btn-add-cart:hover {
            background-color: var(--brand-deep);
        }

        /* 4. Footer Styling */
        footer {
            background-color: var(--brand-deep);
            color: white;
            padding: 3rem 0;
            margin-top: 5rem;
            border-top: 5px solid var(--brand-purple);
        }

    </style>
</head>
<body>

    {% include 'partials/navbar.html.twig' %}

    <main>
        <header class="admin-header">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <a href="{{ base_path }}/events/{{ event_id }}" class="text-purple text-decoration-none fw-bold small mb-2 d-inline-block">
                            <i class="bi bi-arrow-left"></i> {{ trans('evtickets.back') }}
                        </a>
                        <h1 class="fw-800 display-6 mb-1 text-uppercase">{{ event.title|default(trans('evtickets.tickets')) }}</h1>
                        <p class="text-muted mb-0">
                            <i class="bi bi-geo-alt-fill text-purple"></i> {{ event.venue_name|default('Venue TBD') }}
                            <span class="mx-2">|</span>
                            <i class="bi bi-calendar-event text-purple"></i> {{ event.date }}
                        </p>
                    </div>
                    <div class="col-md-4 text-md-end mt-3 mt-md-0">
                        <div class="p-3 border-start border-4 border-purple bg-white shadow-sm">
                            <span class="d-block text-muted small fw-bold">{{ trans('evtickets.total') }}</span>
                            <span class="h4 fw-800 mb-0">{{ tickets|length }} {{ trans('evtickets.tickets') }}</span>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <div class="container mb-5">
            {% if tickets is empty %}
            <div class="text-center py-5">
                <i class="bi bi-ticket-perforated display-1 text-muted mb-4 opacity-25"></i>
                <p class="text-muted fs-4">{{ trans('tadmin.no_tickets_event') }}</p>
                <a href="{{ base_path }}/tickets/create" class="btn-mgmt mt-3">
                    <i class="bi bi-plus-lg me-2"></i> {{ trans('tadmin.crud.new') }}
                </a>
            </div>
            {% else %}
            <div class="row g-4">
                {% for ticket in tickets %}
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <article class="ticket-card">
                        <div class="ticket-visual">
                            <i class="bi bi-ticket-perforated-fill ticket-icon"></i>
                            <span class="price-badge">${{ ticket.price }}</span>
                        </div>

                        <div class="card-content">
                            <h3 class="h5 fw-800 mb-1">{{ trans('tadmin.section') }} {{ ticket.row }}</h3>
                            <p class="text-muted small mb-0">{{ trans('evtickets.seat') }} {{ ticket.seat }}</p>
                        </div>

                        <div class="card-footer">
                            <form action="{{ base_path }}/cart/add" method="POST">
                                <input type="hidden" name="ticket_id" value="{{ ticket.id }}">
                                <input type="hidden" name="quantity" value="1">
                                <button type="submit" class="btn-add-cart">
                                    <i class="bi bi-cart-plus me-2"></i> {{ trans('evtickets.button') }}
                                </button>
                            </form>
                        </div>
                    </article>
                </div>
                {% endfor %}
            </div>
            {% endif %}
        </div>
    </main>

    <!-- Shared Footer -->
    <footer>
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <div class="fw-800 text-uppercase letter-spacing-1 mb-2">{{ trans('app.title') }}</div>
                    <p class="small opacity-75 mb-0">&copy; 2026 {{ trans('app.title') }} Inc. {{ trans('footer.rights') }}</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <div class="d-flex justify-content-md-end gap-3 mt-3 mt-md-0">
                        <a href="#" class="text-white opacity-75 text-decoration-none small">Terms</a>
                        <a href="#" class="text-white opacity-75 text-decoration-none small">Privacy</a>
                        <a href="#" class="text-white opacity-75 text-decoration-none small">Support</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
