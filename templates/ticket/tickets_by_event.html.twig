{% extends "layout.html.twig" %}
{% block title %}{{ trans('evtickets.tickets') }} - {{ trans('app.title') }}{% endblock %}
{% block head %}
<style>

    /* 1. Reset & Global Styles */
    * { border-radius: 0 !important; }

    body {
        background-color: var(--bg-light);
        color: #1a202c;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    main { flex: 1; }

    /* 2. Header Section */
    .admin-header {
        background: white;
        padding: 3rem 0;
        border-bottom: 2px solid var(--brand-purple);
        margin-bottom: 3rem;
    }

    .btn-mgmt {
        background: white;
        border: 2px solid var(--brand-deep);
        color: var(--brand-deep);
        font-weight: 700;
        padding: 10px 20px;
        text-transform: uppercase;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: all 0.2s;
    }

    .btn-mgmt:hover {
        background: var(--brand-deep);
        color: white;
    }

    /* 3. Ticket Card Design */
    .ticket-card {
        border: 2px solid var(--brand-deep);
        background: white;
        transition: all 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        box-shadow: 8px 8px 0px rgba(55, 24, 64, 0.1);
    }

    .ticket-card:hover {
        transform: translate(-4px, -4px);
        box-shadow: 12px 12px 0px rgba(55, 24, 64, 0.15);
    }

    .ticket-visual {
        background: var(--brand-purple);
        height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        border-bottom: 2px dashed white;
    }

    .ticket-icon {
        color: rgba(255,255,255,0.2) !important;
        font-size: 5rem;
        position: absolute;
    }

    .price-badge {
        position: relative;
        z-index: 2;
        background: #ffffff;
        color: var(--brand-purple);
        font-weight: 800;
        padding: 8px 16px;
        font-size: 1.2rem;
        border: 2px solid var(--brand-deep);
        text-align: center;
        line-height: 1.2;
    }

    .price-badge.on-sale {
        background: #e53e3e;
        color: #ffffff;
        border-color: #c53030;
    }

    .price-badge .original-price {
        font-size: 0.75rem;
        font-weight: 600;
        opacity: 0.8;
        text-decoration: line-through;
        display: block;
    }

    .price-badge .sale-price {
        font-size: 1.2rem;
        font-weight: 800;
        display: block;
    }

    .sale-ribbon {
        position: absolute;
        top: 0;
        left: 0;
        background: #e53e3e;
        color: white;
        font-size: 0.65rem;
        font-weight: 800;
        padding: 4px 10px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        z-index: 3;
        border-bottom: 1px solid #c53030;
        border-right: 1px solid #c53030;
    }

    .card-content {
        padding: 1.5rem;
        flex-grow: 1;
        text-align: center;
    }

    .card-footer {
        padding: 1rem;
        background: white;
        border-top: 1px solid #eee;
    }

    .btn-add-cart {
        background-color: var(--brand-purple);
        color: white;
        border: none;
        padding: 12px;
        width: 100%;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: background 0.2s;
    }

    .btn-add-cart:hover {
        background-color: var(--brand-deep);
    }

    /* 4. Footer Styling */
    footer {
        background-color: var(--brand-deep);
        color: white;
        padding: 3rem 0;
        margin-top: 5rem;
        border-top: 5px solid var(--brand-purple);
    }

</style>
{% endblock %}
{% block content %}

    <header class="admin-header">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <a href="{{ base_path }}/events/{{ event_id }}" class="text-purple text-decoration-none fw-bold small mb-2 d-inline-block">
                            <i class="bi bi-arrow-left"></i> {{ trans('evtickets.back') }}
                        </a>
                        <h1 class="fw-800 display-6 mb-1 text-uppercase">{{ event.title|default(trans('evtickets.tickets')) }}</h1>
                        <p class="text-muted mb-0">
                            <i class="bi bi-geo-alt-fill text-purple"></i> {{ event.venue_name|default('Venue TBD') }}
                            <span class="mx-2">|</span>
                            <i class="bi bi-calendar-event text-purple"></i> {{ event.date|default('') }}
                        </p>
                    </div>
                    <div class="col-md-4 text-md-end mt-3 mt-md-0">
                        <div class="p-3 border-start border-4 border-purple bg-white shadow-sm">
                            <span class="d-block text-muted small fw-bold">{{ trans('evtickets.total') }}</span>
                            <span class="h4 fw-800 mb-0">{{ tickets|length }} {{ trans('evtickets.tickets') }}</span>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <div class="container mb-5">
            {% if tickets is empty %}
            <div class="text-center py-5">
                <i class="bi bi-ticket-perforated display-1 text-muted mb-4 opacity-25"></i>
                <p class="text-muted fs-4">{{ trans('tadmin.no_tickets_event') }}</p>
                <a href="{{ base_path }}/tickets/create" class="btn-mgmt mt-3">
                    <i class="bi bi-plus-lg me-2"></i> {{ trans('tadmin.crud.new') }}
                </a>
            </div>
            {% else %}
            <div class="row g-4">
                {% for ticket in tickets %}
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <article class="ticket-card">
                        <div class="ticket-visual">
                            <i class="bi bi-ticket-perforated-fill ticket-icon"></i>
                            {% if ticket.on_sale %}
                                {# Sale ribbon in the corner makes it immediately obvious the ticket is discounted #}
                                <span class="sale-ribbon">{{ trans('evtickets.on_sale') }}</span>
                                <span class="price-badge on-sale">
                                    <span class="original-price">${{ ticket.price|number_format(2) }}</span>
                                    <span class="sale-price">${{ ticket.effective_price|number_format(2) }}</span>
                                </span>
                            {% else %}
                                <span class="price-badge">${{ ticket.price|number_format(2) }}</span>
                            {% endif %}
                        </div>

                        <div class="card-content">
                            <h3 class="h5 fw-800 mb-1">{{ trans('tadmin.section') }} {{ ticket.row }}</h3>
                            <p class="text-muted small mb-0">{{ trans('evtickets.seat') }} {{ ticket.seat }}</p>
                        </div>

                        <div class="card-footer">
                            <form action="{{ base_path }}/cart/add" method="POST">
                                <input type="hidden" name="ticket_id" value="{{ ticket.id }}">
                                <input type="hidden" name="quantity" value="1">
                                <button type="submit" class="btn-add-cart">
                                    <i class="bi bi-cart-plus me-2"></i> {{ trans('evtickets.button') }}
                                </button>
                            </form>
                        </div>
                    </article>
                </div>
                {% endfor %}
            </div>
            {% endif %}
        </div>

{% endblock %}
