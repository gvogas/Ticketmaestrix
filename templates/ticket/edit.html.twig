{% extends "base.html.twig" %}

{% block title %}Edit Ticket - TicketMaestrix{% endblock %}

{% block content %}
<div class="page-header">
    <h2>Edit Ticket</h2>
    <a href="{{ base_path }}/tickets" class="btn btn-secondary">Back to Tickets</a>
</div>

<form action="{{ base_path }}/tickets/{{ ticket.id }}/update" method="post" class="form">
    <div class="form-group">
        <label for="event_id">Event:</label>
        <select id="event_id" name="event_id" required>
            <option value="">— Select an event —</option>
            {% for event in events %}
            <option value="{{ event.id }}" {% if event.id == ticket.event_id %}selected{% endif %}>
                {{ event.title }} ({{ event.date }})
            </option>
            {% endfor %}
        </select>
    </div>

    <div class="form-group">
        <label for="row">Row:</label>
        <input type="text" id="row" name="row" value="{{ ticket.row }}" required>
    </div>

    <div class="form-group">
        <label for="seat">Seat:</label>
        <input type="text" id="seat" name="seat" value="{{ ticket.seat }}" required>
    </div>

    <div class="form-group">
        <label for="price">Price ($):</label>
        <input type="number" id="price" name="price" value="{{ ticket.price }}" min="0" step="0.01" required>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Update Ticket</button>
        <a href="{{ base_path }}/tickets" class="btn btn-secondary">Cancel</a>
    </div>
</form>
{% endblock %}
