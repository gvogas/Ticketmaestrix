{% extends "layout.html.twig" %}
{% block title %}{{ trans('app.title') }} - {{ trans('checkout.page_title') }}{% endblock %}
{% block navbar %}{% endblock %}
{% block footer %}{% endblock %}
{% block head %}
<style>
    body {
        background: linear-gradient(135deg, #a060a8 0%, #4a215d 100%);
        min-height: 100vh;
    }
    /* Center content vertically within the flex-grow-1 main */
    main {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
    }
    .checkout-container {
        max-width: 500px;
        width: 100%;
    }
    .logo-circle {
        width: 60px;
        height: 60px;
        background-color: white;
        color: #7b2cbf;
        font-size: 30px;
    }
    .btn-stripe {
        background-color: #635BFF;
        color: white !important;
        border: none;
        padding: 0.8rem;
        font-size: 1.05rem;
        font-weight: 600;
        border-radius: 0.5rem;
        transition: background-color 0.25s ease;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        cursor: pointer;
    }
    .btn-stripe:hover {
        background-color: #4B44CC;
        color: white !important;
    }
    .alert-error-tm {
        background: #fdecea;
        border: 1px solid #ef9a9a;
        color: #c62828;
        border-radius: 0.5rem;
        padding: 0.75rem 1rem;
        font-size: 0.9rem;
    }
</style>
{% endblock %}
{% block content %}

    <div class="text-center text-white mb-4">
        <div class="logo-circle rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow">
            <i class="bi bi-ticket-perforated-fill"></i>
        </div>
        <h1 class="fw-bold display-5">{{ trans('checkout.page_title') }}</h1>
        <p class="fs-5 opacity-75">{{ trans('checkout.subtitle') }}</p>
    </div>

    <div class="card checkout-container shadow-lg border-0 rounded-4 p-4 p-sm-5">

        {% if error %}
        <div class="alert-error-tm mb-4">
            <i class="bi bi-x-circle-fill me-2"></i>{{ error }}
        </div>
        {% endif %}

      
        <div class="mb-3 p-3 bg-light rounded-3 border text-center">
            <label class="form-label d-block text-muted small text-uppercase fw-bold">{{ trans('checkout.subtotal') }}</label>
            <span class="fs-5 text-dark">${{ subtotal|number_format(2) }}</span>
        </div>

        {% if discount > 0 %}
        <div class="mb-3 p-3 bg-light rounded-3 border text-center">
            <label class="form-label d-block text-muted small text-uppercase fw-bold">{{ trans('checkout.points_discount') }}</label>
            <span class="fs-5 text-success">-${{ discount|number_format(2) }}</span>
        </div>
        {% endif %}

        <div class="mb-3 p-3 bg-light rounded-3 border text-center">
            <label class="form-label d-block text-muted small text-uppercase fw-bold">{{ trans('checkout.service_fee') }}</label>
            <span class="fs-5 text-dark">${{ service_fee|number_format(2) }}</span>
        </div>

        <div class="mb-4 p-3 bg-light rounded-3 border text-center">
            <label class="form-label d-block text-muted small text-uppercase fw-bold">{{ trans('checkout.total') }}</label>
            <span class="display-6 fw-bold text-dark">${{ total|number_format(2) }}</span>
        </div>

        <form action="{{ base_path }}/checkout" method="POST">
            <input type="hidden" name="points_to_use" value="{{ points_to_use }}">
            <button type="submit" class="btn-stripe">
                {# Stripe "S" wordmark #}
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 28 28" fill="white" aria-hidden="true">
                    <path d="M13.976 9.15c-2.172-.806-3.356-1.426-3.356-2.409 0-.831.683-1.305 1.901-1.305
                             2.227 0 4.515.858 6.09 1.631l.89-5.494C18.252.975 15.697 0 12.165 0
                             9.667 0 7.589.654 6.104 1.872 4.56 3.147 3.757 4.992 3.757 7.218
                             c0 4.039 2.467 5.76 6.476 7.219 2.585.92 3.445 1.574 3.445 2.583
                             0 .98-.84 1.545-2.354 1.545-1.875 0-4.965-.921-6.99-2.109l-.9 5.555
                             C5.175 22.99 8.385 24 11.714 24c2.641 0 4.843-.624 6.328-1.813
                             1.664-1.305 2.525-3.236 2.525-5.732 0-4.128-2.524-5.851-6.591-7.305z"/>
                </svg>
                {{ trans('checkout.pay_button') }}
            </button>
        </form>

        <div class="text-center mt-3">
            <a href="{{ base_path }}/cart" class="text-muted small">
                <i class="bi bi-arrow-left"></i> {{ trans('checkout.back_to_cart') }}
            </a>
        </div>
    </div>

    <div class="text-center mt-4 text-white-50 px-4" style="font-size: 0.85rem; max-width: 500px;">
        {{ trans('checkout.secure_notice') }}
    </div>

{% endblock %}
