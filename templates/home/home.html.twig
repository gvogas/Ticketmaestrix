{% extends "layout.html.twig" %}
{% block title %}{{ trans('app.title') }}{% endblock %}
{% block head %}
<style>
    body { background-color: var(--bg-light); font-family: 'Inter', sans-serif; }

    /* Hero Section */
    .hero-section {
        background: linear-gradient(135deg, var(--brand-dark) 0%, var(--brand-purple) 100%);
        color: white;
        padding: 5rem 0;
        text-align: center;
    }
    .search-container { max-width: 600px; margin: 2rem auto; position: relative; }
    .search-container .form-control { border-radius: 50px; padding: 0.8rem 1.5rem 0.8rem 2.5rem; transition: border-radius 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease; }

    .stat-badge { font-size: 1.5rem; font-weight: 800; display: block; }
    .stat-label { font-size: 0.8rem; opacity: 0.8; }

    /* Categories */
    .category-pill {
        border: 1px solid #dee2e6;
        border-radius: 50px;
        padding: 0.4rem 1.2rem;
        font-size: 0.85rem;
        color: #666;
        text-decoration: none;
        transition: all 0.2s;
    }
    .category-pill:hover, .category-pill.active {
        background-color: var(--brand-purple);
        color: white;
        border-color: var(--brand-purple);
    }

    /* Event Cards */
    .event-card {
        border: none;
        border-radius: 12px;
        overflow: hidden;
        background: white;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        transition: transform 0.2s;
        height: 100%;
    }
    .event-card:hover { transform: translateY(-5px); }
    .event-img-container { position: relative; height: 180px; background: #eee; }
    .event-img { width: 100%; height: 100%; object-fit: cover; }

    .badge-sale { position: absolute; top: 10px; left: 10px; background: #ff4d4d; color: white; padding: 2px 10px; border-radius: 4px; font-size: 0.7rem; font-weight: bold; }
    .badge-tickets { position: absolute; top: 10px; right: 10px; background: rgba(155, 81, 224, 0.8); color: white; padding: 2px 10px; border-radius: 4px; font-size: 0.7rem; }

    .event-body { padding: 1.25rem; }
    .event-cat { font-size: 0.65rem; text-transform: uppercase; font-weight: 800; color: #999; margin-bottom: 0.25rem; }
    .event-title { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; }
    .event-meta { font-size: 0.75rem; color: #777; margin-bottom: 0.2rem; }
    .event-price { font-weight: 800; color: var(--brand-purple); font-size: 1.1rem; }

    .btn-details {
        background: var(--accent-purple);
        color: white;
        font-size: 0.8rem;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        text-decoration: none;
        display: inline-block; 
    }

    /* Live-search animations */
    @keyframes sp-rotate { to { transform: rotate(360deg); } }
    .search-spinner { width:14px; height:14px; border:2px solid #e8e0f0; border-top-color:#9b51e0; border-radius:50%; animation:sp-rotate 0.6s linear infinite; flex-shrink:0; display:inline-block; }
    #homeSearchResults { opacity:0; transform:translateY(-4px); transition:opacity 0.15s ease, transform 0.15s ease; border:1px solid #e8e0f0; border-top:none; border-radius:0 0 16px 16px; box-shadow:0 4px 20px rgba(0,0,0,0.12); }
    #homeSearchResults.open { opacity:1; transform:translateY(0); }
    @keyframes row-in { from { opacity:0; transform:translateY(4px); } to { opacity:1; transform:none; } }
    .row-in { animation:row-in 0.15s ease both; }

    /* Connected search — active state */
    .search-active .form-control { border:2px solid #9b51e0; border-bottom:1px solid #ede8f5; border-radius:16px 16px 0 0; box-shadow:0 0 0 3px rgba(155,81,224,0.15); }
    .search-active #homeSearchResults { border:2px solid #9b51e0; border-top:1px solid #ede8f5; border-radius:0 0 16px 16px; box-shadow:0 12px 28px rgba(155,81,224,0.18); }

    #homeSearchIcon { position:absolute; left:14px; top:50%; transform:translateY(-50%); color:#adb5bd; pointer-events:none; font-size:0.95rem; transition:color 0.15s ease; z-index:2; }
    .search-active #homeSearchIcon { color:#9b51e0; }

    /* Map Banner */
    .map-banner {
        background: linear-gradient(90deg, #8a2be2, #4169e1);
        color: white;
        border-radius: 16px;
        padding: 3rem;
        text-align: center;
        margin-top: 4rem;
    }
</style>
{% endblock %}
{% block content %}

    <!-- Hero Section -->
    <header class="hero-section">
        <div class="container">
            <h1 class="display-4 fw-bold">{{ trans('home.header') }}</h1>
            <p class="opacity-75">{{ trans('home.subheader') }}</p>

            <div class="search-container" style="position:relative;">
                <i class="bi bi-search" id="homeSearchIcon"></i>
                <input type="text" class="form-control" id="homeSearch" placeholder="{{ trans('home.search_placeholder') }}" autocomplete="off">

                <div id="homeSearchResults" style="position:absolute;top:100%;width:100%;z-index:1000;display:none;background:#fff;overflow:hidden;"></div>
            </div>

            <div class="d-flex justify-content-center gap-5 mt-4">
                <div><span class="stat-badge">{{ live_count }}</span><span class="stat-label">{{ trans('home.live') }}</span></div>
                <div><span class="stat-badge">{{ on_sale_count }}</span><span class="stat-label">{{ trans('home.onsale') }}</span></div>
                <div><span class="stat-badge">10%</span><span class="stat-label">{{ trans('home.points') }}</span></div>
            </div>
        </div>
    </header>

    <div class="container mt-4">
        <!-- Categories -->
        {# Category pills are pulled from the categories table; "All" is a static reset. #}
        <div class="d-flex gap-2 mb-5 flex-wrap justify-content-center">
            <a href="{{ base_path }}/" class="category-pill active">{{ trans('home.all') }}</a>
            {% for c in categories %}
                <a href="{{ base_path }}/events/category/{{ c.id }}" class="category-pill">{{ trans_cat(c.name) }}</a>
            {% endfor %}
        </div>

        <!-- Tickets On Sale Section -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold"><i class="bi bi-tags text-danger me-2"></i>{{ trans('home.sale') }}</h4>
            <a href="#" class="text-muted small text-decoration-none">{{ trans('home.view') }} <i class="bi bi-arrow-right"></i></a>
        </div>

        <div class="row g-4 mb-5">
            {% for event in featured %}
            <div class="col-md-4">
                <div class="event-card">
                    <div class="event-img-container">
                        <span class="badge-sale">{{ trans('home.badge_sale') }}</span>
                        {% if event.event_image %}
                            <img src="{{ event.event_image }}" alt="{{ event.title }}" class="event-img">
                        {% else %}
                            <div class="event-img"></div>
                        {% endif %}
                    </div>
                    <div class="event-body">
                        <h6 class="event-title">{{ event.title }}</h6>
                        <div class="event-meta"><i class="bi bi-calendar"></i> {{ event.date }}</div>
                        <div class="event-meta"><i class="bi bi-geo-alt"></i> {{ event.venue_name }}</div>
                        <div class="mt-3">
                            <span class="event-price">
                                {% if event.min_price is not null %}${{ event.min_price|number_format(2) }}{% else %}{{ trans('home.tba') }}{% endif %}
                            </span>
                            <a href="{{ base_path }}/events/{{ event.id }}" class="btn-details">{{ trans('home.details') }}</a>
                        </div>
                    </div>
                </div>
            </div>
            {% else %}
                <div class="col-12 text-center text-muted py-4">{{ trans('home.no_sale') }}</div>
            {% endfor %}
        </div>

        <!-- All Events Section -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold">{{ trans('home.event') }}</h4>
            <span class="text-muted small">{{ events|length }} {{ trans('home.nb_events') }}</span>
        </div>

        <div class="row g-4">
            {% for event in events %}
            <div class="col-md-4">
                <div class="event-card">
                    <div class="event-img-container">
                        {% if event.event_image %}
                            <img src="{{ event.event_image }}" alt="{{ event.title }}" class="event-img">
                        {% else %}
                            <div class="event-img"></div>
                        {% endif %}
                    </div>
                    <div class="event-body">
                        <h6 class="event-title">{{ event.title }}</h6>
                        <div class="event-meta"><i class="bi bi-calendar"></i> {{ event.date }}</div>
                        <div class="event-meta"><i class="bi bi-geo-alt"></i> {{ event.venue_name }}</div>
                        <div class="mt-3">
                            <span class="event-price">
                                {% if event.min_price is not null %}${{ event.min_price|number_format(2) }}{% else %}{{ trans('home.tba') }}{% endif %}
                            </span>
                            <a href="{{ base_path }}/events/{{ event.id }}" class="btn-details">{{ trans('home.details') }}</a>
                        </div>
                    </div>
                </div>
            </div>
            {% else %}
                <div class="col-12 text-center text-muted py-4">{{ trans('home.no_events') }}</div>
            {% endfor %}
        </div>

        <!-- Bottom Map CTA -->
        <div class="map-banner">
            <i class="bi bi-geo-alt-fill display-4 mb-3 d-block"></i>
            <h3 class="fw-bold">{{ trans('home.map_header') }}</h3>
            <p>{{ trans('home.map_subheader') }}</p>
            <a href="{{ base_path }}/map" class="btn btn-light rounded-pill px-5 mt-2 fw-bold">{{ trans('home.map_button') }}</a>
        </div>
    </div>


{% endblock %}
{% block scripts %}
    <script>
    (function () {
        var COLORS = ['#9b51e0','#5E246E','#22c55e','#f59e0b','#3b82f6','#ef4444'];
        // Deterministic color from category name — same category always gets the same dot color.
        function catColor(name) {
            var h = 0, s = name || '';
            for (var i = 0; i < s.length; i++) h += s.charCodeAt(i);
            // Use COLORS.length so adding/removing palette entries never causes a silent miss.
            return COLORS[h % COLORS.length];
        }

        // Builds one result row using DOM methods only — no innerHTML with untrusted data.
        function buildRow(ev) {
            var a = document.createElement('a');
            // Only allow root-relative paths — guards against javascript: or data: URIs in API response.
            var url = (typeof ev.url === 'string' && ev.url.startsWith('/')) ? ev.url : '#';
            a.setAttribute('href', url);
            a.style.cssText = 'display:flex;align-items:center;gap:10px;padding:7px 14px;border-bottom:1px solid #f5f0fa;text-decoration:none;';

            var dot = document.createElement('span');
            // Set layout styles via cssText and color separately — avoids concatenating untrusted values into cssText.
            dot.style.cssText = 'width:8px;height:8px;border-radius:50%;flex-shrink:0;';
            dot.style.background = catColor(ev.category);

            var body = document.createElement('span');
            body.style.cssText = 'flex:1;min-width:0;display:flex;flex-direction:column;justify-content:center;overflow:hidden;';

            var title = document.createElement('span');
            title.style.cssText = 'font-size:13px;font-weight:600;color:#1a1a2e;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;';
            title.textContent = ev.title;

            var meta = document.createElement('span');
            meta.style.cssText = 'font-size:11px;color:#aaa;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px;';
            var locationParts = [ev.venue_name, ev.venue_address].filter(Boolean);
            var locationStr = locationParts.join(' · ');
            meta.textContent = locationStr + (ev.date ? (locationStr ? ', ' : '') + ev.date : '');

            body.appendChild(title);
            body.appendChild(meta);

            var price = document.createElement('span');
            price.style.cssText = 'font-size:12px;font-weight:700;color:#5E246E;white-space:nowrap;flex-shrink:0;';
            // null/undefined means price is not yet set — show "TBA" rather than "Free".
            price.textContent = (ev.min_price === null || ev.min_price === undefined)
                ? '{{ trans('home.tba')|e('js') }}'
                : (ev.min_price > 0 ? '$' + parseFloat(ev.min_price).toFixed(2) : 'Free');

            a.appendChild(dot);
            a.appendChild(body);
            a.appendChild(price);
            a.addEventListener('mouseenter', function () { a.style.background = '#f9f4ff'; });
            a.addEventListener('mouseleave', function () { a.style.background = ''; });
            return a;
        }

        function buildFooter() {
            var f = document.createElement('div');
            f.style.cssText = 'padding:7px 14px;font-size:11px;color:#bbb;background:#fafafa;border-top:1px solid #f0eaf8;text-align:center;';
            f.textContent = '{{ trans('home.search_enter')|e('js') }}';
            return f;
        }

        function buildSpinner() {
            var s = document.createElement('div');
            s.style.cssText = 'padding:10px 14px;display:flex;align-items:center;justify-content:center;gap:8px;';
            var spin = document.createElement('span');
            spin.className = 'search-spinner';
            var txt = document.createElement('span');
            txt.style.cssText = 'font-size:12px;color:#aaa;';
            txt.textContent = 'Searching…';
            s.appendChild(spin);
            s.appendChild(txt);
            return s;
        }

        function hideResults() {
            results.classList.remove('open');
            // Only deactivate the pill if the input is actually empty — keeps active state
            // while results are loading or hidden but the user is still typing.
            if (!input.value.trim()) searchContainer.classList.remove('search-active');
            setTimeout(function () { results.style.display = 'none'; }, 150);
        }

        var input           = document.getElementById('homeSearch');

        var results         = document.getElementById('homeSearchResults');
        var searchContainer = input.parentElement;
        var timer, controller;

        function goSearch() {
            var q = input.value.trim();
            if (q) window.location.href = '{{ base_path }}/events?q=' + encodeURIComponent(q);
        }

        input.addEventListener('keydown', function (e) { if (e.key === 'Enter') goSearch(); });

        input.addEventListener('input', function () {
            var q = input.value.trim();
            clearTimeout(timer);
            if (controller) controller.abort();
            if (!q) { hideResults(); return; }

            // Activate the connected pill immediately on first keystroke.
            searchContainer.classList.add('search-active');

            timer = setTimeout(function () {
                // Show spinner immediately while the request is in flight.
                while (results.firstChild) results.removeChild(results.firstChild);
                results.appendChild(buildSpinner());
                results.style.display = 'block';
                requestAnimationFrame(function () { results.classList.add('open'); });

                controller = new AbortController();
                fetch('{{ base_path }}/api/search?q=' + encodeURIComponent(q), { signal: controller.signal })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        while (results.firstChild) results.removeChild(results.firstChild);
                        if (!data.length) {
                            var empty = document.createElement('div');
                            empty.style.cssText = 'padding:12px 14px;font-size:13px;color:#aaa;text-align:center;';
                            empty.textContent = '{{ trans('home.no_events')|e('js') }}';
                            results.appendChild(empty);
                            return;
                        }
                        data.forEach(function (ev, i) {
                            var row = buildRow(ev);
                            row.classList.add('row-in');
                            // Stagger each row by 30ms so they cascade in rather than all appearing at once.
                            row.style.animationDelay = (i * 30) + 'ms';
                            results.appendChild(row);
                        });
                        results.appendChild(buildFooter());
                    })
                    .catch(function (e) {
                        if (e.name === 'AbortError') return;
                        hideResults();
                    });
            }, 300);
        });

        document.addEventListener('click', function (e) {
            if (!input.parentElement.contains(e.target)) {
                searchContainer.classList.remove('search-active');
                hideResults();
            }
        });
    })();
    </script>
{% endblock %}
