<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TicketMaestrix - Payment Successful</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            background: linear-gradient(135deg, #a060a8 0%, #4a215d 100%);
            min-height: 100vh;
        }
        .success-container {
            max-width: 500px;
            width: 100%;
        }
        .btn-primary-tm {
            background-color: #5E246E;
            color: white !important;
            border: none;
            padding: 0.8rem;
            font-size: 1.05rem;
            font-weight: 600;
            border-radius: 0.5rem;
            transition: background-color 0.25s ease;
            width: 100%;
            display: block;
            text-align: center;
            text-decoration: none;
        }
        .btn-primary-tm:hover {
            background-color: #371840;
        }
    </style>
</head>
<body class="d-flex flex-column align-items-center justify-content-center p-3">

    <div class="text-center text-white mb-4">
        <div class="rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow"
             style="width:60px;height:60px;background:white;color:#2e7d32;font-size:30px;">
            <i class="bi bi-check-lg"></i>
        </div>
        <h1 class="fw-bold display-5">Payment Received!</h1>
        <p class="fs-5 opacity-75">Thank you for your purchase.</p>
    </div>

    <div class="card success-container shadow-lg border-0 rounded-4 p-4 p-sm-5 text-center">
        <p class="text-muted mb-4">
            Your payment was successful. Your order and tickets will appear in your
            profile within a few moments.
        </p>
        <a href="{{ base_path }}/profile" class="btn-primary-tm mb-3">
            <i class="bi bi-person-circle me-2"></i>View My Profile
        </a>
        <div class="mt-2">
            <a href="{{ base_path }}/events" class="text-muted small">Browse more events</a>
        </div>
    </div>

</body>
</html>
