{% extends "layout.html.twig" %}
{% block title %}{{ trans('order.order_label') }} #{{ orderItem.id }} - {{ trans('app.title') }}{% endblock %}
{% block head %}
<style>
    body { background-color: #F8F9FA; }
</style>
{% endblock %}
{% block content %}

    <div class="container py-5" style="max-width: 600px;">
        <a href="{{ base_path }}/orders/{{ orderItem.order_id }}" class="text-decoration-none text-muted small mb-4 d-inline-block">
            <i class="bi bi-arrow-left"></i> {{ trans('order.back_to_order') }}
        </a>

        <div class="card border-0 shadow-sm rounded-4 p-4">
            <h4 class="fw-bold mb-4">{{ trans('order.order_label') }} #{{ orderItem.id }}</h4>

            <ul class="list-group list-group-flush mb-4">
                <li class="list-group-item px-0">
                    <i class="bi bi-receipt me-2 text-muted"></i>
                    <strong>{{ trans('order.order_label') }}:</strong> #{{ orderItem.order_id }}
                </li>
                <li class="list-group-item px-0">
                    <i class="bi bi-ticket-perforated me-2 text-muted"></i>
                    <strong>{{ trans('order.ticket_label') }}:</strong> #{{ orderItem.ticket_id }}
                </li>
                <li class="list-group-item px-0">
                    <i class="bi bi-123 me-2 text-muted"></i>
                    <strong>{{ trans('order.quantity_label') }}:</strong> {{ orderItem.quantity }}
                </li>
            </ul>

            <form action="{{ base_path }}/order-items/{{ orderItem.id }}/delete" method="POST" class="d-inline">
                {{ csrf_field() }}
                <button type="submit" class="btn btn-sm btn-outline-danger"
                        onclick="return confirm('{{ trans('confirm.delete_order_item')|e('js') }}')">
                    <i class="bi bi-trash"></i> {{ trans('order.delete') }}
                </button>
            </form>
        </div>
    </div>

{% endblock %}
