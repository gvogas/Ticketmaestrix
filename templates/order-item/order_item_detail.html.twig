<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Item #{{ orderItem.id }} - TicketMaestrix</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root { --brand-purple: #5E246E; }
        body { background-color: #F8F9FA; }
    </style>
</head>
<body>
    {% include 'partials/navbar.html.twig' %}

    <div class="container py-5" style="max-width: 600px;">
        <a href="{{ base_path }}/orders/{{ orderItem.order_id }}" class="text-decoration-none text-muted small mb-4 d-inline-block">
            <i class="bi bi-arrow-left"></i> Back to Order
        </a>

        <div class="card border-0 shadow-sm rounded-4 p-4">
            <h4 class="fw-bold mb-4">Order Item #{{ orderItem.id }}</h4>

            <ul class="list-group list-group-flush mb-4">
                <li class="list-group-item px-0">
                    <i class="bi bi-receipt me-2 text-muted"></i>
                    <strong>Order:</strong> #{{ orderItem.order_id }}
                </li>
                <li class="list-group-item px-0">
                    <i class="bi bi-ticket-perforated me-2 text-muted"></i>
                    <strong>Ticket:</strong> #{{ orderItem.ticket_id }}
                </li>
                <li class="list-group-item px-0">
                    <i class="bi bi-123 me-2 text-muted"></i>
                    <strong>Quantity:</strong> {{ orderItem.quantity }}
                </li>
            </ul>

            <form action="{{ base_path }}/order-items/{{ orderItem.id }}/delete" method="POST" class="d-inline">
                <button type="submit" class="btn btn-sm btn-outline-danger"
                        onclick="return confirm('Delete this item?')">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
