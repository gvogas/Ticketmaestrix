<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Items - TicketMaestrix</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root { --brand-purple: #5E246E; }
        body { background-color: #F8F9FA; }
    </style>
</head>
<body>
    {% include 'partials/navbar.html.twig' %}

    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <a href="{{ base_path }}/orders/{{ order_id }}" class="text-decoration-none text-muted small">
                    <i class="bi bi-arrow-left"></i> Back to Order
                </a>
                <h4 class="fw-bold mb-0 mt-2">
                    <i class="bi bi-list-ul me-2" style="color:var(--brand-purple)"></i>
                    Items in Order #{{ order_id }}
                </h4>
            </div>
            <span class="text-muted small">{{ order_items|length }} item(s)</span>
        </div>

        {% if order_items is empty %}
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox display-4 d-block mb-3"></i>
            No items found for this order.
        </div>
        {% else %}
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4">Item #</th>
                        <th>Ticket</th>
                        <th>Quantity</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in order_items %}
                    <tr>
                        <td class="px-4 text-muted small">#{{ item.id }}</td>
                        <td>
                            <a href="{{ base_path }}/tickets/{{ item.ticket_id }}" class="text-decoration-none fw-bold">
                                Ticket #{{ item.ticket_id }}
                            </a>
                        </td>
                        <td>{{ item.quantity }}</td>
                        <td>
                            <a href="{{ base_path }}/order-items/{{ item.id }}" class="btn btn-sm btn-outline-secondary">
                                View
                            </a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
