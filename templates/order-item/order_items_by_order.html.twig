{% extends "layout.html.twig" %}
{% block title %}{{ trans('order.items_in') }} - {{ trans('app.title') }}{% endblock %}
{% block head %}
<style>
    :root { --brand-purple: #5E246E; }
    body { background-color: #F8F9FA; }
</style>
{% endblock %}
{% block content %}

    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <a href="{{ base_path }}/orders/{{ order_id }}" class="text-decoration-none text-muted small">
                    <i class="bi bi-arrow-left"></i> {{ trans('order.back_to_order') }}
                </a>
                <h4 class="fw-bold mb-0 mt-2">
                    <i class="bi bi-list-ul me-2" style="color:var(--brand-purple)"></i>
                    {{ trans('order.items_in') }} #{{ order_id }}
                </h4>
            </div>
            <span class="text-muted small">{{ order_items|length }} item(s)</span>
        </div>

        {% if order_items is empty %}
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox display-4 d-block mb-3"></i>
            {{ trans('order.no_items') }}
        </div>
        {% else %}
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4">{{ trans('order.col_item') }} #</th>
                        <th>{{ trans('order.col_ticket') }}</th>
                        <th>{{ trans('order.col_quantity') }}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in order_items %}
                    <tr>
                        <td class="px-4 text-muted small">#{{ item.id }}</td>
                        <td>
                            <a href="{{ base_path }}/tickets/{{ item.ticket_id }}" class="text-decoration-none fw-bold">
                                {{ trans('order.ticket_label') }} #{{ item.ticket_id }}
                            </a>
                        </td>
                        <td>{{ item.quantity }}</td>
                        <td>
                            <a href="{{ base_path }}/order-items/{{ item.id }}" class="btn btn-sm btn-outline-secondary">
                                {{ trans('order.view') }}
                            </a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}
    </div>

{% endblock %}
