{% extends "layout.html.twig" %}

{% block title %}Home - ticketmaestrix{% endblock %}

{% block content %}

{# Hero Section #}
<section class="bg-gradient-to-b from-purple-900 via-purple-800 to-purple-700 text-white py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4">
            Discover Amazing Events Near You
        </h1>
        <p class="text-purple-200 text-sm sm:text-base max-w-xl mx-auto mb-8">
            From concerts to movies, sports to theater - find and book tickets for unforgettable experiences
        </p>

        {# Search bar #}
        <form action="{{ base_path }}/events" method="GET" class="max-w-2xl mx-auto mb-10">
            <div class="flex items-center bg-white rounded-full overflow-hidden shadow-lg">
                <div class="pl-5 text-gray-400">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <input type="text" name="q"
                       placeholder="Search events, venues, or locations..."
                       class="flex-1 px-4 py-3 text-gray-800 text-sm focus:outline-none"
                       autocomplete="off">
                <button type="submit"
                        class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-3 text-sm font-semibold transition">
                    Search
                </button>
            </div>
        </form>

        {# Stats #}
        <div class="flex justify-center gap-12 sm:gap-16">
            <div>
                <span class="text-2xl sm:text-3xl font-bold">8+</span>
                <p class="text-purple-200 text-xs mt-1">Live Events</p>
            </div>
            <div>
                <span class="text-2xl sm:text-3xl font-bold">4</span>
                <p class="text-purple-200 text-xs mt-1">On Sale</p>
            </div>
            <div>
                <span class="text-2xl sm:text-3xl font-bold">10%</span>
                <p class="text-purple-200 text-xs mt-1">Points Back</p>
            </div>
        </div>
    </div>
</section>

{# Category Tabs #}
<section class="bg-white sticky top-16 z-40 py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3 overflow-x-auto scrollbar-hide">
            <a href="{{ base_path }}/events" class="whitespace-nowrap px-5 py-2 text-sm font-medium rounded-full bg-gray-200 text-gray-700 hover:bg-gray-300 transition">All</a>
            <a href="{{ base_path }}/events?category=concert" class="whitespace-nowrap px-5 py-2 text-sm font-medium rounded-full bg-gray-200 text-gray-700 hover:bg-gray-300 transition">Concert</a>
            <a href="{{ base_path }}/events?category=movie" class="whitespace-nowrap px-5 py-2 text-sm font-medium rounded-full bg-gray-200 text-gray-700 hover:bg-gray-300 transition">Movie</a>
            <a href="{{ base_path }}/events?category=sports" class="whitespace-nowrap px-5 py-2 text-sm font-medium rounded-full bg-gray-200 text-gray-700 hover:bg-gray-300 transition">Sports</a>
            <a href="{{ base_path }}/events?category=theater" class="whitespace-nowrap px-5 py-2 text-sm font-medium rounded-full bg-gray-200 text-gray-700 hover:bg-gray-300 transition">Theater</a>
            <a href="{{ base_path }}/events?category=raffle" class="whitespace-nowrap px-5 py-2 text-sm font-medium rounded-full bg-gray-200 text-gray-700 hover:bg-gray-300 transition">Raffle</a>
            <a href="{{ base_path }}/events?category=festival" class="whitespace-nowrap px-5 py-2 text-sm font-medium rounded-full bg-gray-200 text-gray-700 hover:bg-gray-300 transition">Festival</a>
        </div>
    </div>
</section>

