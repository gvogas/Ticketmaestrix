<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - TicketMaestrix</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --brand-purple: #5E246E;
            --brand-dark: #371840;
            --accent-purple: #9b51e0;
            --bg-light: #F8F9FA;
        }
        body { background-color: var(--bg-light); font-family: 'Inter', sans-serif; }

        /* Hero Section */
        .hero-section {
            background: linear-gradient(135deg, var(--brand-dark) 0%, var(--brand-purple) 100%);
            color: white;
            padding: 5rem 0;
            text-align: center;
        }
        .search-container { max-width: 600px; margin: 2rem auto; position: relative; }
        .search-container .form-control { border-radius: 50px; padding: 0.8rem 1.5rem; }
        .btn-search { position: absolute; right: 5px; top: 5px; border-radius: 50px; background: var(--brand-purple); color: white; padding: 0.5rem 1.5rem; border: none; }

        .stat-badge { font-size: 1.5rem; font-weight: 800; display: block; }
        .stat-label { font-size: 0.8rem; opacity: 0.8; }

        /* Categories */
        .category-pill {
            border: 1px solid #dee2e6;
            border-radius: 50px;
            padding: 0.4rem 1.2rem;
            font-size: 0.85rem;
            color: #666;
            text-decoration: none;
            transition: all 0.2s;
        }
        .category-pill:hover, .category-pill.active {
            background-color: var(--brand-purple);
            color: white;
            border-color: var(--brand-purple);
        }

        /* Event Cards */
        .event-card {
            border: none;
            border-radius: 12px;
            overflow: hidden;
            background: white;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            transition: transform 0.2s;
            height: 100%;
        }
        .event-card:hover { transform: translateY(-5px); }
        .event-img-container { position: relative; height: 180px; background: #eee; }
        .event-img { width: 100%; height: 100%; object-fit: cover; }
        
        .badge-sale { position: absolute; top: 10px; left: 10px; background: #ff4d4d; color: white; padding: 2px 10px; border-radius: 4px; font-size: 0.7rem; font-weight: bold; }
        .badge-tickets { position: absolute; top: 10px; right: 10px; background: rgba(155, 81, 224, 0.8); color: white; padding: 2px 10px; border-radius: 4px; font-size: 0.7rem; }

        .event-body { padding: 1.25rem; }
        .event-cat { font-size: 0.65rem; text-transform: uppercase; font-weight: 800; color: #999; margin-bottom: 0.25rem; }
        .event-title { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; }
        .event-meta { font-size: 0.75rem; color: #777; margin-bottom: 0.2rem; }
        .event-price { font-weight: 800; color: var(--brand-purple); font-size: 1.1rem; }
        
        .btn-details { 
            background: var(--accent-purple); 
            color: white; 
            font-size: 0.75rem; 
            padding: 0.4rem 1rem; 
            border-radius: 6px; 
            text-decoration: none;
            float: right;
        }

        /* Map Banner */
        .map-banner {
            background: linear-gradient(90deg, #8a2be2, #4169e1);
            color: white;
            border-radius: 16px;
            padding: 3rem;
            text-align: center;
            margin-top: 4rem;
        }
    </style>
</head>
<body>

    {% include 'partials/navbar.html.twig' %}

    <!-- Hero Section -->
    <header class="hero-section">
        <div class="container">
            <h1 class="display-4 fw-bold">Discover Amazing Events Near You</h1>
            <p class="opacity-75">From concerts to movies, sports to theater - find and book tickets for unforgettable experiences</p>
            
            <div class="search-container">
                <input type="text" class="form-control" placeholder="Search events, venues, or locations...">
                <button class="btn-search">Search</button>
            </div>

            <div class="d-flex justify-content-center gap-5 mt-4">
                <div><span class="stat-badge">8+</span><span class="stat-label">Live Events</span></div>
                <div><span class="stat-badge">4</span><span class="stat-label">On Sale</span></div>
                <div><span class="stat-badge">10%</span><span class="stat-label">Points Back</span></div>
            </div>
        </div>
    </header>

    <div class="container mt-4">
        <!-- Categories -->
        <div class="d-flex gap-2 mb-5 flex-wrap justify-content-center">
            <a href="#" class="category-pill active">All</a>
            <a href="#" class="category-pill">Concert</a>
            <a href="#" class="category-pill">Movie</a>
            <a href="#" class="category-pill">Sports</a>
            <a href="#" class="category-pill">Theater</a>
            <a href="#" class="category-pill">Raffle</a>
            <a href="#" class="category-pill">Festival</a>
        </div>

        <!-- Tickets On Sale Section -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold"><i class="bi bi-tags text-danger me-2"></i>Tickets On Sale</h4>
            <a href="#" class="text-muted small text-decoration-none">View All <i class="bi bi-arrow-right"></i></a>
        </div>
        
        <div class="row g-4 mb-5">
            {% for i in 1..3 %}
            <div class="col-md-4">
                <div class="event-card">
                    <div class="event-img-container">
                        <span class="badge-sale">ON SALE</span>
                        <div class="event-img"></div>
                    </div>
                    <div class="event-body">
                        <div class="event-cat">Concert</div>
                        <h6 class="event-title">Summer Music Festival 2026</h6>
                        <div class="event-meta"><i class="bi bi-calendar"></i> Tue, Jul 14, 2026 at 19:00</div>
                        <div class="event-meta"><i class="bi bi-geo-alt"></i> Central Park Amphitheater</div>
                        <div class="mt-3">
                            <span class="event-price">$89.99</span>
                            <a href="#" class="btn-details">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>

        <!-- All Events Section -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold">All Events</h4>
            <span class="text-muted small">8 events found</span>
        </div>

        <div class="row g-4">
            <!-- Example of dynamic grid items -->
            {% set items = [
                {'title': 'Summer Music Festival 2026', 'cat': 'Concert', 'price': '89.99'},
                {'title': 'The Midnight Chronicles', 'cat': 'Movie', 'price': '15.99'},
                {'title': 'Charity Raffle - Win a Tesla', 'cat': 'Raffle', 'price': '25.00'},
                {'title': 'NBA Finals Game 5', 'cat': 'Sports', 'price': '299.99'},
                {'title': 'Hamilton - Broadway Musical', 'cat': 'Theater', 'price': '179.99'},
                {'title': 'Jazz in the City', 'cat': 'Concert', 'price': '45.00'}
            ] %}

            {% for item in items %}
            <div class="col-md-4">
                <div class="event-card">
                    <div class="event-img-container">
                        <div class="event-img"></div>
                    </div>
                    <div class="event-body">
                        <div class="event-cat">{{ item.cat }}</div>
                        <h6 class="event-title">{{ item.title }}</h6>
                        <div class="event-meta"><i class="bi bi-calendar"></i> May 15, 2026</div>
                        <div class="event-meta"><i class="bi bi-geo-alt"></i> Local Venue</div>
                        <div class="mt-3">
                            <span class="event-price">${{ item.price }}</span>
                            <a href="#" class="btn-details">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>

        <!-- Bottom Map CTA -->
        <div class="map-banner">
            <i class="bi bi-geo-alt-fill display-4 mb-3 d-block"></i>
            <h3 class="fw-bold">Discover Local Events</h3>
            <p>Use our interactive map to find events happening near you</p>
            <button class="btn btn-light rounded-pill px-5 mt-2 fw-bold">Explore Map</button>
        </div>
    </div>

    <footer class="py-5 text-center text-muted small">
        &copy; 2026 TicketMaestrix. All rights reserved.
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>