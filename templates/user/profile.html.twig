{% extends "layout.html.twig" %}
{% block title %}{{ user.first_name }} - {{ trans('app.title') }}{% endblock %}
{% block head %}
<style>
    body { background-color: var(--bg-light); font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }

    .profile-header {
        background: linear-gradient(135deg, var(--brand-dark) 0%, var(--brand-purple) 100%);
        border-radius: 16px;
        color: white;
        padding: 2.5rem;
    }

    .profile-avatar {
        width: 90px;
        height: 90px;
        background: rgba(255, 255, 255, 0.15);
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
    }

    .custom-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
        transition: transform 0.2s;
    }

    .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
    }

    .reward-item {
        border: 1px solid #f0f0f0;
        border-radius: 14px;
        padding: 1.25rem;
        margin-bottom: 1rem;
    }

    .reward-unlocked {
        border-color: #D3F9D8;
        background-color: #F3FDF6;
    }

    .progress { height: 10px; border-radius: 10px; background-color: #e9ecef; }
    .progress-bar { background-color: var(--brand-purple); }
</style>
{% endblock %}
{% block content %}

    <div class="container py-5">

        <!-- User Banner -->
        <div class="profile-header d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 gap-4">
            <div class="d-flex align-items-center gap-4 text-center text-md-start flex-column flex-md-row">
                <div class="profile-avatar">
                    {% if user.avatar %}
                        <img src="{{ base_path }}{{ user.avatar }}" alt="{{ user.first_name }}"
                             style="width:100%;height:100%;object-fit:cover;border-radius:50%;">
                    {% else %}
                        <i class="bi bi-person"></i>
                    {% endif %}
                </div>
                <div>
                    <h1 class="mb-1 fw-bold">{{ user.first_name }} {{ user.last_name }}</h1>
                    <p class="mb-0 opacity-75">{{ user.email }}</p>
                    <a href="{{ base_path }}/editprofile" class="btn btn-sm btn-outline-light mt-2">
                        <i class="bi bi-pencil"></i> {{ trans('profile.edit_btn') }}
                    </a>
                </div>
            </div>
            <div class="text-center text-md-end">
                <h2 class="mb-0 fw-bold display-6">{{ user.points|default('0') }}</h2>
                <small class="text-uppercase tracking-wider opacity-75">{{ trans('profile.rewards') }}</small>
            </div>
        </div>

        <!-- Stats Row -->
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card custom-card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-light text-primary"><i class="bi bi-ticket-perforated"></i></div>
                        <div>
                            <h4 class="mb-0 fw-bold">{{ tickets_count|default('0') }}</h4>
                            <small class="text-muted">{{ trans('profile.stat_tickets') }}</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card custom-card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-light text-success"><i class="bi bi-currency-dollar"></i></div>
                        <div>
                            <h4 class="mb-0 fw-bold">${{ total_spent|default('0.00') }}</h4>
                            <small class="text-muted">{{ trans('profile.stat_spent') }}</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card custom-card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-light text-info"><i class="bi bi-calendar-check"></i></div>
                        <div>
                            <h4 class="mb-0 fw-bold">{{ events_attended|default('0') }}</h4>
                            <small class="text-muted">{{ trans('profile.stat_events') }}</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Main Content: History -->
            <div class="col-lg-8">
                <!-- Purchase History -->
                <div class="card custom-card p-4 mb-4">
                    <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
                        <i class="bi bi-clock-history text-muted"></i> {{ trans('profile.purchase_history') }}
                    </h5>

                    {# `orders` is stdClass[] from OrderModel::findByUserWithItems —
                       each entry carries an `items` array of line items already
                       joined to ticket + event. Mirrors the points_history wiring below. #}
                    {% if orders is empty %}
                    <div class="text-center py-5">
                        <i class="bi bi-ticket-perforated text-light mb-3" style="font-size: 5rem;"></i>
                        <h5 class="text-dark">{{ trans('profile.no_purchases') }}</h5>
                        <a href="{{ base_path }}/events" class="btn btn-outline-primary rounded-pill mt-2">{{ trans('flash.browse_events') }}</a>
                    </div>
                    {% else %}
                    <div class="d-flex flex-column gap-3">
                        {% for order in orders %}
                        <div class="border rounded-3 p-3">
                            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                                <div>
                                    <div class="fw-bold">{{ trans('order.order_label') }} #{{ order.id }}</div>
                                    <small class="text-muted">{{ order.order_time }}</small>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold" style="color:var(--brand-purple)">${{ order.total_price|number_format(2) }}</div>
                                    {% if order.status == 1 %}
                                        <span class="badge bg-success">{{ trans('order.status_completed') }}</span>
                                    {% else %}
                                        <span class="badge bg-warning text-dark">{{ trans('order.status_pending') }}</span>
                                    {% endif %}
                                </div>
                            </div>

                            {% if order.items|length > 0 %}
                            <ul class="list-unstyled small text-muted mb-0 mt-3 pt-3 border-top">
                                {% for item in order.items %}
                                <li class="d-flex align-items-start gap-2 py-1">
                                    <i class="bi bi-ticket-perforated mt-1"></i>
                                    <span>
                                        {{ item.quantity }} ×
                                        {% if item.event_id %}
                                            <a href="{{ base_path }}/events/{{ item.event_id }}" class="text-decoration-none fw-semibold">{{ item.event_title }}</a>
                                        {% else %}
                                            <span class="fw-semibold">{{ item.event_title|default('—') }}</span>
                                        {% endif %}
                                        {% if item.row or item.seat %}
                                            <span class="text-muted">— {{ item.row }} {{ item.seat }}</span>
                                        {% endif %}
                                    </span>
                                </li>
                                {% endfor %}
                            </ul>
                            {% endif %}
                        </div>
                        {% endfor %}
                    </div>

                    {% include 'partials/pagination.html.twig' with {
                        current_page: current_page,
                        total_pages:  total_pages,
                        base_url:     base_path ~ '/profile',
                        query_params: query_params
                    } only %}
                    {% endif %}
                </div>

                <!-- Points History -->
                <div class="card custom-card p-4">
                    <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
                        <i class="bi bi-stars text-warning"></i> {{ trans('profile.points_history') }}
                    </h5>
                    {% if points_history is empty %}
                    <div class="text-center py-4">
                        <p class="text-muted mb-0">{{ trans('profile.no_points') }}</p>
                    </div>
                    {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="text-muted small text-uppercase">Date</th>
                                    <th class="text-muted small text-uppercase">Description</th>
                                    <th class="text-muted small text-uppercase text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for entry in points_history %}
                                <tr>
                                    <td class="small text-muted">{{ entry.created_at|date('M j, Y g:i A') }}</td>
                                    <td class="small">{{ entry.description }}</td>
                                    <td class="small text-end fw-bold {% if entry.amount > 0 %}text-success{% else %}text-danger{% endif %}">
                                        {{ entry.amount > 0 ? '+' : '' }}{{ entry.amount }} pts
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% endif %}
                </div>
            </div>

            <!-- Sidebar: Rewards -->
            <div class="col-lg-4">
                <div class="card custom-card p-4">
                    <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
                        <i class="bi bi-gift text-muted"></i> {{ trans('profile.rewards') }}
                    </h5>

                    <div class="d-flex justify-content-between mb-2 small">
                        <span class="text-muted">{{ trans('profile.progress_label') }}</span>
                        <span class="text-primary fw-bold">{{ user.points|default('0') }} pts</span>
                    </div>
                    {# Progress bar maxes out at 2,500 pts — the top reward tier. Halved
                       from the old 5,000 to track the new 500 / 1,250 tier pacing. #}
                    <div class="progress mb-4">
                        <div class="progress-bar" style="width: {{ (user.points / 2500 * 100)|default(5) }}%"></div>
                    </div>

                    {# $10 Off tier now unlocks at 500 points (was 1,000). At the 20% earn
                       rate this means ~$25 of spend rather than ~$100, matching the new
                       reward pacing. The actual discount is still applied via the cart's
                       points slider at 1 pt = $0.01 — this card is purely a milestone display. #}
                    <div class="reward-item {% if user.points >= 500 %}reward-unlocked{% endif %}">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h6 class="fw-bold mb-0">$10 Off Next Purchase</h6>
                            {% if user.points >= 500 %}
                                <span class="badge bg-success rounded-pill">Unlocked</span>
                            {% endif %}
                        </div>
                        <small class="text-muted">500 points</small>
                    </div>

                    {# Free Service Fee tier halved from 2,500 → 1,250 to match the new
                       reward pacing. Mirrors tier 1's unlock-badge structure so both
                       cards behave consistently when the user crosses the threshold. #}
                    <div class="reward-item {% if user.points >= 1250 %}reward-unlocked{% endif %}">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h6 class="fw-bold mb-0 {% if user.points < 1250 %}text-muted{% endif %}">Free Service Fee (1 use)</h6>
                            {% if user.points >= 1250 %}
                                <span class="badge bg-success rounded-pill">Unlocked</span>
                            {% endif %}
                        </div>
                        <small class="text-muted">1,250 points</small>
                    </div>

                    <div class="mt-4 p-3 bg-light rounded-3 text-center border">
                        <small class="text-muted">
                            <i class="bi bi-stars text-warning me-1"></i>
                            {{ trans('profile.earn_callout') }}
                        </small>
                    </div>
                </div>
            </div>
        </div>
        <!-- Danger Zone -->
        <div class="card custom-card p-4 mt-4 border border-danger">
            <h5 class="fw-bold mb-2 text-danger d-flex align-items-center gap-2">
                <i class="bi bi-exclamation-triangle-fill"></i> Danger Zone
            </h5>
            <p class="text-muted small mb-3">Permanently delete your account and all associated data. This cannot be undone.</p>
            <button type="button" class="btn btn-outline-danger btn-sm"
                    data-bs-toggle="modal" data-bs-target="#deleteAccountModal">
                Delete My Account
            </button>
        </div>

        <!-- Delete confirmation modal -->
        <div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-labelledby="deleteAccountModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header border-0">
                        <h5 class="modal-title fw-bold text-danger" id="deleteAccountModalLabel">Delete Account</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-muted">
                        Are you sure? This will permanently delete your account and cannot be undone.
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                        <form method="POST" action="{{ base_path }}/profile/delete" style="display:inline;">
                            <button type="submit" class="btn btn-danger btn-sm">Yes, delete my account</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
