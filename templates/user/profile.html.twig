{% extends "layout.html.twig" %}
{% block title %}{{ user.first_name }} - {{ trans('app.title') }}{% endblock %}
{% block head %}
<style>
    body { background-color: var(--bg-light); font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }

    .profile-header {
        background: linear-gradient(135deg, var(--brand-dark) 0%, var(--brand-purple) 100%);
        border-radius: 16px;
        color: white;
        padding: 2.5rem;
    }

    .profile-avatar {
        width: 90px;
        height: 90px;
        background: rgba(255, 255, 255, 0.15);
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
    }

    .custom-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
        transition: transform 0.2s;
    }

    .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
    }

    .reward-item {
        border: 1px solid #f0f0f0;
        border-radius: 14px;
        padding: 1.25rem;
        margin-bottom: 1rem;
    }

    .reward-unlocked {
        border-color: #D3F9D8;
        background-color: #F3FDF6;
    }

    .progress { height: 10px; border-radius: 10px; background-color: #e9ecef; }
    .progress-bar { background-color: var(--brand-purple); }
</style>
{% endblock %}
{% block content %}

    <div class="container py-5">

        <!-- User Banner -->
        <div class="profile-header d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 gap-4">
            <div class="d-flex align-items-center gap-4 text-center text-md-start flex-column flex-md-row">
                <div class="profile-avatar">
                    {% if user.avatar %}
                        <img src="{{ base_path }}{{ user.avatar }}" alt="{{ user.first_name }}"
                             style="width:100%;height:100%;object-fit:cover;border-radius:50%;">
                    {% else %}
                        <i class="bi bi-person"></i>
                    {% endif %}
                </div>
                <div>
                    <h1 class="mb-1 fw-bold">{{ user.first_name }} {{ user.last_name }}</h1>
                    <p class="mb-0 opacity-75">{{ user.email }}</p>
                    <a href="{{ base_path }}/editprofile" class="btn btn-sm btn-outline-light mt-2">
                        <i class="bi bi-pencil"></i> {{ trans('profile.edit_btn') }}
                    </a>
                </div>
            </div>
            <div class="text-center text-md-end">
                <h2 class="mb-0 fw-bold display-6">{{ user.points|default('0') }}</h2>
                <small class="text-uppercase tracking-wider opacity-75">{{ trans('profile.rewards') }}</small>
            </div>
        </div>

        <!-- Stats Row -->
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card custom-card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-light text-primary"><i class="bi bi-ticket-perforated"></i></div>
                        <div>
                            <h4 class="mb-0 fw-bold">{{ tickets_count|default('0') }}</h4>
                            <small class="text-muted">{{ trans('profile.stat_tickets') }}</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card custom-card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-light text-success"><i class="bi bi-currency-dollar"></i></div>
                        <div>
                            <h4 class="mb-0 fw-bold">${{ total_spent|default('0.00') }}</h4>
                            <small class="text-muted">{{ trans('profile.stat_spent') }}</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card custom-card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-light text-info"><i class="bi bi-calendar-check"></i></div>
                        <div>
                            <h4 class="mb-0 fw-bold">{{ events_attended|default('0') }}</h4>
                            <small class="text-muted">{{ trans('profile.stat_events') }}</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Main Content: History -->
            <div class="col-lg-8">
                <!-- Purchase History -->
                <div class="card custom-card p-4 mb-4">
                    <h5 class="fw-bold mb-5 d-flex align-items-center gap-2">
                        <i class="bi bi-clock-history text-muted"></i> {{ trans('profile.purchase_history') }}
                    </h5>
                    <div class="text-center py-5">
                        <i class="bi bi-ticket-perforated text-light mb-3" style="font-size: 5rem;"></i>
                        <h5 class="text-dark">{{ trans('profile.no_purchases') }}</h5>
                        <a href="{{ base_path }}/events" class="btn btn-outline-primary rounded-pill mt-2">{{ trans('flash.browse_events') }}</a>
                    </div>
                </div>

                <!-- Points History -->
                <div class="card custom-card p-4">
                    <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
                        <i class="bi bi-stars text-warning"></i> {{ trans('profile.points_history') }}
                    </h5>
                    {% if points_history is empty %}
                    <div class="text-center py-4">
                        <p class="text-muted mb-0">{{ trans('profile.no_points') }}</p>
                    </div>
                    {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="text-muted small text-uppercase">Date</th>
                                    <th class="text-muted small text-uppercase">Description</th>
                                    <th class="text-muted small text-uppercase text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for entry in points_history %}
                                <tr>
                                    <td class="small text-muted">{{ entry.created_at|date('M j, Y g:i A') }}</td>
                                    <td class="small">{{ entry.description }}</td>
                                    <td class="small text-end fw-bold {% if entry.amount > 0 %}text-success{% else %}text-danger{% endif %}">
                                        {{ entry.amount > 0 ? '+' : '' }}{{ entry.amount }} pts
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% endif %}
                </div>
            </div>

            <!-- Sidebar: Rewards -->
            <div class="col-lg-4">
                <div class="card custom-card p-4">
                    <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
                        <i class="bi bi-gift text-muted"></i> {{ trans('profile.rewards') }}
                    </h5>

                    <div class="d-flex justify-content-between mb-2 small">
                        <span class="text-muted">{{ trans('profile.progress_label') }}</span>
                        <span class="text-primary fw-bold">{{ user.points|default('0') }} pts</span>
                    </div>
                    <div class="progress mb-4">
                        <div class="progress-bar" style="width: {{ (user.points / 5000 * 100)|default(5) }}%"></div>
                    </div>

                    <div class="reward-item {% if user.points >= 1000 %}reward-unlocked{% endif %}">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h6 class="fw-bold mb-0">$10 Off Next Purchase</h6>
                            {% if user.points >= 1000 %}
                                <span class="badge bg-success rounded-pill">Unlocked</span>
                            {% endif %}
                        </div>
                        <small class="text-muted">1,000 points</small>
                    </div>

                    <div class="reward-item">
                        <h6 class="fw-bold mb-1 text-muted">Free Service Fee (1 use)</h6>
                        <small class="text-muted">2,500 points</small>
                    </div>

                    <div class="mt-4 p-3 bg-light rounded-3 text-center border">
                        <small class="text-muted">
                            <i class="bi bi-stars text-warning me-1"></i>
                            {{ trans('profile.earn_callout') }}
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
