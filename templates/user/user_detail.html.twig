<!DOCTYPE html>
<html lang="{{ current_locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ user.first_name }} {{ user.last_name }} - {{ trans('app.title') }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root { --brand-purple: #5E246E; --brand-dark: #371840; }
        body { background-color: #F8F9FA; }
        .avatar { width: 80px; height: 80px; background: var(--brand-purple); color: white; font-size: 2rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
        .badge-role { background-color: var(--brand-purple); }
    </style>
</head>
<body>
    {% include 'partials/navbar.html.twig' %}

    <div class="container py-5" style="max-width: 640px;">
        <a href="{{ base_path }}/" class="text-decoration-none text-muted small mb-4 d-inline-block">
            <i class="bi bi-arrow-left"></i> {{ trans('useradmin.back') }}
        </a>

        <div class="card border-0 shadow-sm rounded-4 p-4">
            <div class="d-flex align-items-center gap-4 mb-4">
                <div class="avatar">{{ user.first_name|first|upper }}</div>
                <div>
                    <h4 class="fw-bold mb-0">{{ user.first_name }} {{ user.last_name }}</h4>
                    <span class="badge badge-role text-white">{{ user.role }}</span>
                </div>
            </div>

            <ul class="list-group list-group-flush">
                <li class="list-group-item px-0">
                    <i class="bi bi-envelope me-2 text-muted"></i>
                    <strong>{{ trans('useradmin.email_label') }}:</strong> {{ user.email }}
                </li>
                <li class="list-group-item px-0">
                    <i class="bi bi-shield me-2 text-muted"></i>
                    <strong>{{ trans('useradmin.role_label') }}:</strong> {{ user.role }}
                </li>
            </ul>

            <div class="mt-4 d-flex gap-2">
                <a href="{{ base_path }}/editprofile" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-pencil"></i> {{ trans('useradmin.edit') }}
                </a>
                <form action="{{ base_path }}/users/{{ user.id }}/delete" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-outline-danger"
                            onclick="return confirm('{{ trans('confirm.delete_user')|e('js') }}')">
                        <i class="bi bi-trash"></i> {{ trans('useradmin.delete') }}
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
