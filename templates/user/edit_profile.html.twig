{% extends "layout.html.twig" %}
{% block title %}{{ trans('editprofile.heading') }} - {{ trans('app.title') }}{% endblock %}
{% block head %}
<style>
    body { background-color: #f8f9fa; font-family: 'Inter', sans-serif; }
    .edit-card { border: none; border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.06); }
    .avatar-circle { width: 80px; height: 80px; background: #6f42c1; color: white; display: flex; align-items: center; justify-content: center; font-size: 2rem; border-radius: 50%; position: relative; }
    .camera-icon { position: absolute; bottom: 0; right: 0; background: #9b51e0; border: 2px solid white; border-radius: 50%; width: 24px; height: 24px; font-size: 0.75rem; display: flex; align-items: center; justify-content: center; }
    .form-label { font-weight: 600; font-size: 0.9rem; color: #333; }
    .form-control { border-radius: 8px; padding: 0.6rem 1rem; border: 1px solid #dee2e6; }
    .btn-save { background: linear-gradient(90deg, #6f42c1, #4e73df); border: none; color: white; padding: 0.8rem 2rem; border-radius: 8px; font-weight: 600; }
    .danger-zone { border: 1px solid #ffcfcf; background: #fff5f5; border-radius: 12px; }
</style>
{% endblock %}
{% block content %}

    <div class="container py-5" style="max-width: 800px;">
        <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
            <div>
                <h2 class="fw-bold mb-1">{{ trans('editprofile.heading') }}</h2>
                <p class="text-muted mb-0">{{ trans('editprofile.subheading') }}</p>
            </div>
            <a href="{{ base_path }}/profile" class="text-muted text-decoration-none small py-1">
                <i class="bi bi-x-lg"></i> {{ trans('editprofile.cancel') }}
            </a>
        </div>

        <form action="{{ base_path }}/editprofile" method="POST">
            <div class="card edit-card p-4 p-md-5 mb-4">
                <div class="d-flex align-items-center gap-4 mb-5">
                    <div class="avatar-circle">
                        {{ user.first_name|first|upper }}
                        <div class="camera-icon"><i class="bi bi-camera-fill"></i></div>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">{{ trans('editprofile.photo_heading') }}</h6>
                        <p class="text-muted small mb-2">{{ trans('editprofile.photo_desc') }}</p>
                        <button type="button" class="btn px-3 py-2 text-white" style="background: #9b51e0; border-radius: 6px; font-size: 0.875rem;">{{ trans('editprofile.upload_btn') }}</button>
                    </div>
                </div>

                <h6 class="fw-bold mb-4">{{ trans('editprofile.personal_heading') }}</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label">{{ trans('editprofile.name_label') }}</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-person"></i></span>
                            <input type="text" name="user[name]" required
                                   class="form-control{{ errors.name is defined ? ' is-invalid' : '' }}"
                                   value="{{ input.name ?? (user.first_name ~ ' ' ~ user.last_name) }}">
                        </div>
                        {% if errors.name is defined %}
                            <div class="invalid-feedback">{{ errors.name | first }}</div>
                        {% endif %}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">{{ trans('editprofile.email_label') }}</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-envelope"></i></span>
                            <input type="email" name="user[email]" required
                                   class="form-control{{ errors.email is defined ? ' is-invalid' : '' }}"
                                   value="{{ input.email ?? user.email }}">
                        </div>
                        {% if errors.email is defined %}
                            <div class="invalid-feedback">{{ errors.email | first }}</div>
                        {% endif %}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">{{ trans('editprofile.birthday_label') }}</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-calendar3"></i></span>
                            <input type="date" name="user[birthday]" class="form-control">
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">{{ trans('editprofile.location_label') }}</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-geo-alt"></i></span>
                            <input type="text" name="user[location]" class="form-control" placeholder="{{ trans('editprofile.location_ph') }}">
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">{{ trans('editprofile.bio_label') }}</label>
                        <textarea class="form-control" rows="4" placeholder="{{ trans('editprofile.bio_ph') }}"></textarea>
                        <div class="text-end text-muted small mt-1">0/500 characters</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">{{ trans('editprofile.password') }}</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-shield-lock"></i></span>
                            <input type="password" name="user[password]" class="form-control" placeholder="{{ trans('editprofile.password.message') }}">
                        </div>
                    </div>
                </div>

                <h6 class="fw-bold mb-3">{{ trans('editprofile.prefs_heading') }}</h6>
                <div class="list-group list-group-flush border rounded-3 mb-4">
                    <label class="list-group-item p-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-bold small">{{ trans('editprofile.email_notif') }}</div>
                                <div class="text-muted extra-small" style="font-size: 0.8rem;">{{ trans('editprofile.email_notif_desc') }}</div>
                            </div>
                            <input class="form-check-input" type="checkbox" checked>
                        </div>
                    </label>
                    <label class="list-group-item p-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-bold small">{{ trans('editprofile.marketing') }}</div>
                                <div class="text-muted extra-small" style="font-size: 0.8rem;">{{ trans('editprofile.marketing_desc') }}</div>
                            </div>
                            <input class="form-check-input" type="checkbox">
                        </div>
                    </label>
                </div>

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-save flex-grow-1"><i class="bi bi-save me-2"></i> {{ trans('editprofile.save_btn') }}</button>
                    <a href="{{ base_path }}/profile" class="btn btn-outline-secondary px-4 py-2 rounded-3">{{ trans('editprofile.cancel_btn') }}</a>
                </div>
            </div>
        </form>

        <div class="danger-zone p-4">
            <h6 class="text-danger fw-bold mb-3">{{ trans('editprofile.danger_header') }}</h6>
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <div class="fw-bold mb-0">{{ trans('editprofile.delete_label') }}</div>
                    <p class="text-muted small mb-0">{{ trans('editprofile.delete_desc') }}</p>
                </div>
                <button class="btn btn-danger px-4 py-2 flex-shrink-0"
                        data-bs-toggle="modal" data-bs-target="#deleteModal">{{ trans('editprofile.delete_btn') }}</button>
            </div>
        </div>
    </div>

    <!-- Delete Account Confirmation Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow">
                <div class="modal-header border-0 pt-4 px-4">
                    <h5 class="fw-bold text-danger">{{ trans('editprofile.delete_label') }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body px-4 pb-4">
                    <p class="mb-0">{{ trans('confirm.delete_account') }}</p>
                </div>
                <div class="modal-footer border-0 pb-4 px-4">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">{{ trans('editprofile.cancel_btn') }}</button>
                    <form action="{{ base_path }}/delete-account" method="POST" class="m-0">
                        <button type="submit" class="btn btn-danger px-4">{{ trans('editprofile.delete_btn') }}</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
