<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile - TicketMaestrix</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="{{ base_path }}/css/forms.css">
    <style>
        body { background-color: #f8f9fa; font-family: 'Inter', sans-serif; }
        .edit-card { border: none; border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.06); }
        .avatar-circle { width: 80px; height: 80px; background: #6f42c1; color: white; display: flex; align-items: center; justify-content: center; font-size: 2rem; border-radius: 50%; position: relative; }
        .camera-icon { position: absolute; bottom: 0; right: 0; background: #9b51e0; border: 2px solid white; border-radius: 50%; width: 24px; height: 24px; font-size: 0.75rem; display: flex; align-items: center; justify-content: center; }
        .form-label { font-weight: 600; font-size: 0.9rem; color: #333; }
        .form-control { border-radius: 8px; padding: 0.6rem 1rem; border: 1px solid #dee2e6; }
        .btn-save { background: linear-gradient(90deg, #6f42c1, #4e73df); border: none; color: white; padding: 0.8rem 2rem; border-radius: 8px; font-weight: 600; }
        .danger-zone { border: 1px solid #ffcfcf; background: #fff5f5; border-radius: 12px; }
    </style>
</head>
<body>

    {% include 'partials/navbar.html.twig' %}

    <div class="container py-5" style="max-width: 800px;">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h2 class="fw-bold mb-1">Edit Profile</h2>
                <p class="text-muted mb-0">Update your personal information</p>
            </div>
            <a href="{{ base_path }}/profile" class="text-muted text-decoration-none small">
                <i class="bi bi-x-lg"></i> Cancel
            </a>
        </div>

        <form action="{{ base_path }}/editprofile" method="POST">
            <div class="card edit-card p-4 p-md-5 mb-4">
                <div class="d-flex align-items-center gap-4 mb-5">
                    <div class="avatar-circle">
                        {{ user.first_name|first|upper }}
                        <div class="camera-icon"><i class="bi bi-camera-fill"></i></div>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Profile Photo</h6>
                        <p class="text-muted small mb-2">Update your profile picture. Max file size: 5MB</p>
                        <button type="button" class="btn btn-sm px-3 py-1 text-white" style="background: #9b51e0; border-radius: 6px;">Upload New Photo</button>
                    </div>
                </div>

                <h6 class="fw-bold mb-4">Personal Information</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label">Full Name *</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-person"></i></span>
                            <input type="text" name="user[name]" required
                                   class="form-control{{ errors.name is defined ? ' is-invalid' : '' }}"
                                   value="{{ input.name ?? (user.first_name ~ ' ' ~ user.last_name) }}">
                        </div>
                        {% if errors.name is defined %}
                            <div class="invalid-feedback">{{ errors.name | first }}</div>
                        {% endif %}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email Address *</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-envelope"></i></span>
                            <input type="email" name="user[email]" required
                                   class="form-control{{ errors.email is defined ? ' is-invalid' : '' }}"
                                   value="{{ input.email ?? user.email }}">
                        </div>
                        {% if errors.email is defined %}
                            <div class="invalid-feedback">{{ errors.email | first }}</div>
                        {% endif %}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phone Number</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-telephone"></i></span>
                            <input type="text" name="user[phone]" class="form-control" value="{{ user.phone_number }}">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Birthday</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-calendar3"></i></span>
                            <input type="date" name="user[birthday]" class="form-control">
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Location</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-geo-alt"></i></span>
                            <input type="text" name="user[location]" class="form-control" placeholder="New York, NY">
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Bio</label>
                        <textarea class="form-control" rows="4" placeholder="Tell us a bit about yourself..."></textarea>
                        <div class="text-end text-muted small mt-1">0/500 characters</div>
                    </div>
                </div>

                <h6 class="fw-bold mb-3">Preferences</h6>
                <div class="list-group list-group-flush border rounded-3 mb-4">
                    <label class="list-group-item p-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-bold small">Email Notifications</div>
                                <div class="text-muted extra-small" style="font-size: 0.8rem;">Receive updates about your tickets and events</div>
                            </div>
                            <input class="form-check-input" type="checkbox" checked>
                        </div>
                    </label>
                    <label class="list-group-item p-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-bold small">Marketing Emails</div>
                                <div class="text-muted extra-small" style="font-size: 0.8rem;">Get notified about special offers and promotions</div>
                            </div>
                            <input class="form-check-input" type="checkbox">
                        </div>
                    </label>
                </div>

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-save flex-grow-1"><i class="bi bi-save me-2"></i> Save Changes</button>
                    <a href="{{ base_path }}/profile" class="btn btn-outline-secondary px-4 py-2 rounded-3">Cancel</a>
                </div>
            </div>
        </form>

        <div class="danger-zone p-4">
            <h6 class="text-danger fw-bold mb-3">Danger Zone</h6>
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="fw-bold mb-0">Delete Account</div>
                    <p class="text-muted small mb-0">Permanently delete your account and all data</p>
                </div>
                <button class="btn btn-danger px-4">Delete Account</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>