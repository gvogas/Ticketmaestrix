{% extends "layout.html.twig" %}
{% block title %}{{ trans('useradmin.header') }} - {{ trans('app.title') }}{% endblock %}
{% block head %}
<style>
    body { background-color: #F8F9FA; font-family: 'Inter', sans-serif; }
    .role-badge-admin { background: #5E246E; color: white; }
    .role-badge-user  { background: #e9ecef; color: #495057; }
</style>
{% endblock %}
{% block content %}

    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">{{ trans('useradmin.header') }}</h2>
            <span class="text-muted">{{ total_users|default(users|length) }} total</span>
        </div>

        <div class="card border-0 shadow-sm rounded-4 p-3">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>{{ trans('useradmin.col_name') }}</th>
                            <th>{{ trans('useradmin.col_email') }}</th>
                            <th>{{ trans('useradmin.col_role') }}</th>
                            <th class="text-end">{{ trans('useradmin.col_actions') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        
                        {% for u in users %}
                            <tr>
                                <td class="text-muted">{{ u.id }}</td>
                                <td><a href="{{ base_path }}/users/{{ u.id }}" class="fw-bold text-decoration-none">{{ u.first_name }} {{ u.last_name }}</a></td>
                                <td>{{ u.email }}</td>
                                <td>
                                    <span class="badge {% if u.role == 'admin' %}role-badge-admin{% else %}role-badge-user{% endif %}">{{ u.role }}</span>
                                </td>
                                <td class="text-end">
                                    <form method="POST" action="{{ base_path }}/users/{{ u.id }}/role" class="d-inline">
                                        {{ csrf_field() }}
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">{{ trans('useradmin.toggle_role') }}</button>
                                    </form>
                                    <form method="POST" action="{{ base_path }}/users/{{ u.id }}/delete" class="d-inline" onsubmit="return confirm('{{ trans('confirm.delete_user')|e('js') }}');">
                                        {{ csrf_field() }}
                                        <button type="submit" class="btn btn-sm btn-outline-danger">{{ trans('useradmin.delete') }}</button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="5" class="text-center text-muted py-4">{{ trans('useradmin.no_users') }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {% include 'partials/pagination.html.twig' with {
            current_page: current_page,
            total_pages:  total_pages,
            base_url:     base_path ~ '/users',
            query_params: query_params
        } only %}
    </div>

{% endblock %}
