<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users - TicketMaestrix Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { background-color: #F8F9FA; font-family: 'Inter', sans-serif; }
        .role-badge-admin { background: #5E246E; color: white; }
        .role-badge-user  { background: #e9ecef; color: #495057; }
    </style>
</head>
<body>

    {% include 'partials/navbar.html.twig' %}

    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">Users</h2>
            <span class="text-muted">{{ users|length }} total</span>
        </div>

        <div class="card border-0 shadow-sm rounded-4 p-3">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {# Loop over every user; admin can toggle role or delete. #}
                        {% for u in users %}
                            <tr>
                                <td class="text-muted">{{ u.id }}</td>
                                <td><a href="{{ base_path }}/users/{{ u.id }}" class="fw-bold text-decoration-none">{{ u.first_name }} {{ u.last_name }}</a></td>
                                <td>{{ u.email }}</td>
                                <td>
                                    <span class="badge {% if u.role == 'admin' %}role-badge-admin{% else %}role-badge-user{% endif %}">{{ u.role }}</span>
                                </td>
                                <td class="text-end">
                                    <form method="POST" action="{{ base_path }}/users/{{ u.id }}/role" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">Toggle role</button>
                                    </form>
                                    <form method="POST" action="{{ base_path }}/users/{{ u.id }}/delete" class="d-inline" onsubmit="return confirm('Delete this user?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="5" class="text-center text-muted py-4">No users yet.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
