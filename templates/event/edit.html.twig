<!DOCTYPE html>
<html lang="{{ current_locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ trans('evadmin.crud.name') }} - {{ trans('app.title') }}</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="{{ base_path }}/css/forms.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');

        body {
            background-color: #ffffff;
            font-family: 'Inter', sans-serif;
            color: #1a202c;
            min-height: 100vh;
        }

        .main-wrapper {
            padding: 60px 0;
        }

        .page-title {
            font-weight: 800;
            color: #5E246E;
            margin-bottom: 2rem;
            font-size: 2rem;
            letter-spacing: -0.02em;
        }

        /* Elevated Card Effect */
        .edit-card-pop {
            background: #ffffff;
            border: 1px solid #f0f0f0;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05),
                        0 20px 25px -5px rgba(0, 0, 0, 0.08);
        }

        .form-label {
            font-weight: 700;
            color: #4a5568;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            margin-bottom: 0.6rem;
        }

        .form-control, .form-select {
            padding: 0.8rem 1rem;
            border: 2px solid #edf2f7;
            border-radius: 10px;
            background-color: #fcfcfc;
        }

        .form-control:focus, .form-select:focus {
            border-color: #5E246E;
            box-shadow: 0 0 0 4px rgba(94, 36, 110, 0.1);
            outline: none;
        }

        /* Medium Image Preview */
        .preview-box {
            margin-top: 15px;
            max-width: 350px;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #edf2f7;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        .preview-img {
            width: 100%;
            height: auto;
            max-height: 200px;
            object-fit: cover;
            display: block;
        }

        /* Button - Forced White Text */
        .btn-update {
            background-color: #5E246E;
            border: none;
            color: #ffffff !important;
            padding: 12px 35px;
            border-radius: 10px;
            font-weight: 700;
            transition: all 0.2s;
        }

        .btn-update:hover {
            background-color: #4a1d56;
            color: #ffffff !important;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(94, 36, 110, 0.2);
        }

        .btn-cancel {
            background-color: #f8fafc;
            color: #718096;
            border: 1.5px solid #edf2f7;
            padding: 12px 30px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-cancel:hover {
            background-color: #edf2f7;
            color: #2d3748;
        }
    </style>
</head>
<body>

    {% include 'partials/navbar.html.twig' %}

    <div class="container main-wrapper">
        <div class="row justify-content-center">
            <div class="col-lg-9">

                <h1 class="page-title">{{ trans('evadmin.crud.name') }}</h1>

                <div class="edit-card-pop">
                    <form action="{{ base_path }}/events/{{ event.id }}/update" method="post">
                        <div class="row g-4">

                            <div class="col-12">
                                <label class="form-label">{{ trans('evadmin.crud.title') }}</label>
                                <input type="text" name="title" required
                                       class="form-control{{ errors.title is defined ? ' is-invalid' : '' }}"
                                       value="{{ input.title ?? event.title }}">
                                {% if errors.title is defined %}
                                    <div class="invalid-feedback">{{ errors.title | first }}</div>
                                {% endif %}
                            </div>

                            <div class="col-12">
                                <label class="form-label">{{ trans('evadmin.crud.description') }}</label>
                                <textarea name="description" required
                                          class="form-control{{ errors.description is defined ? ' is-invalid' : '' }}"
                                          rows="4">{{ input.description ?? event.description }}</textarea>
                                {% if errors.description is defined %}
                                    <div class="invalid-feedback">{{ errors.description | first }}</div>
                                {% endif %}
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">{{ trans('evadmin.crud.category') }}</label>
                                <select name="category_id" required
                                        class="form-select{{ errors.category_id is defined ? ' is-invalid' : '' }}">
                                    {% for category in categories %}
                                    <option value="{{ category.id }}" {% if category.id == event.category_id %}selected{% endif %}>
                                        {{ category.name }}
                                    </option>
                                    {% endfor %}
                                </select>
                                {% if errors.category_id is defined %}
                                    <div class="invalid-feedback">{{ errors.category_id | first }}</div>
                                {% endif %}
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">{{ trans('evadmin.crud.venue') }}</label>
                                <select name="venue_id" required
                                        class="form-select{{ errors.venue_id is defined ? ' is-invalid' : '' }}">
                                    {% for venue in venues %}
                                    <option value="{{ venue.id }}" {% if venue.id == event.venue_id %}selected{% endif %}>
                                        {{ venue.name }}
                                    </option>
                                    {% endfor %}
                                </select>
                                {% if errors.venue_id is defined %}
                                    <div class="invalid-feedback">{{ errors.venue_id | first }}</div>
                                {% endif %}
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">{{ trans('evadmin.crud.date') }}</label>
                                <input type="datetime-local" name="date" required
                                       class="form-control{{ errors.date is defined ? ' is-invalid' : '' }}"
                                       value="{{ input.date ?? event.date }}">
                                {% if errors.date is defined %}
                                    <div class="invalid-feedback">{{ errors.date | first }}</div>
                                {% endif %}
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">{{ trans('evadmin.crud.image') }}</label>
                                <input type="url" name="event_image" class="form-control" value="{{ event.event_image }}">

                                {% if event.event_image %}
                                <div class="preview-box">
                                    <img src="{{ event.event_image }}" class="preview-img" alt="Poster preview">
                                </div>
                                {% endif %}
                            </div>

                            <div class="col-12 mt-5 pt-4 border-top d-flex gap-3 justify-content-end">
                                <a href="{{ base_path }}/events" class="btn btn-cancel">{{ trans('evadmin.crud.cancel') }}</a>
                                <button type="submit" class="btn btn-update">{{ trans('evadmin.crud.update') }}</button>
                            </div>

                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
