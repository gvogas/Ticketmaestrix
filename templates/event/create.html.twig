{% extends "layout.html.twig" %}
{% block title %}{{ trans('evadmin.crud.header') }} - {{ trans('app.title') }}{% endblock %}
{% block head %}
<style>
    body { background-color: var(--bg-light); font-family: 'Inter', sans-serif; }

    /* Consistent Banner Styling */
    .page-banner {
        background: linear-gradient(135deg, var(--brand-dark) 0%, var(--brand-purple) 100%);
        color: white;
        padding: 3rem 0;
        margin-bottom: 3rem;
    }

    /* Form Card Styling */
    .form-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        background: white;
        padding: 2.5rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.9rem;
        color: #444;
        margin-bottom: 0.5rem;
    }

    .form-control, .form-select {
        padding: 0.75rem;
        border-radius: 8px;
        border: 1px solid #dee2e6;
        transition: all 0.2s;
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--accent-purple);
        box-shadow: 0 0 0 0.25rem rgba(155, 81, 224, 0.1);
        outline: none;
    }

    /* Button Styling */
    .btn-create {
        background-color: var(--accent-purple);
        border: none;
        color: white;
        padding: 0.8rem 2rem;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.2s;
    }
    .btn-create:hover {
        background-color: #8339c9;
        color: white;
        transform: translateY(-1px);
    }

    .btn-cancel {
        padding: 0.8rem 2rem;
        border-radius: 10px;
        font-weight: 600;
    }

    /* Navbar placeholder matching your admin dashboard */
    .navbar-placeholder {
        height: 60px;
        background: white;
        border-bottom: 1px solid #eee;
    }
</style>
{% endblock %}
{% block content %}

    <div class="navbar-placeholder"></div>

    <div class="page-banner">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold mb-1">{{ trans('evadmin.crud.header') }}</h2>
                    <p class="mb-0 opacity-75">{{ trans('evadmin.crud.subheader') }}</p>
                </div>
                <a href="{{ base_path }}/events" class="btn btn-outline-light rounded-pill px-4">
                    <i class="bi bi-arrow-left me-2"></i> {{ trans('evadmin.crud.back') }}
                </a>
            </div>
        </div>
    </div>

    <div class="container pb-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card form-card">
                    <form action="{{ base_path }}/events" method="post">
                        {{ csrf_field() }}
                        <div class="row g-4">

                            <div class="col-12">
                                <label for="title" class="form-label">{{ trans('evadmin.crud.title') }}</label>
                                <input type="text" id="title" name="title" required
                                       class="form-control{{ errors.title is defined ? ' is-invalid' : '' }}"
                                        placeholder="{{ trans('ph.event_title') }}"
                                       value="{{ input.title ?? '' }}">
                                {% if errors.title is defined %}
                                    <div class="invalid-feedback">{{ errors.title | first }}</div>
                                {% endif %}
                            </div>

                            <div class="col-md-6">
                                <label for="category_id" class="form-label">{{ trans('evadmin.crud.category') }}</label>
                                <select id="category_id" name="category_id" required
                                        class="form-select{{ errors.category_id is defined ? ' is-invalid' : '' }}">
                                    <option value="" selected disabled>{{ trans('evadmin.crud.select_category') }}</option>
                                    {% for category in categories %}
                                        <option value="{{ category.id }}">{{ trans_cat(category.name) }}</option>
                                    {% endfor %}
                                </select>
                                {% if errors.category_id is defined %}
                                    <div class="invalid-feedback">{{ errors.category_id | first }}</div>
                                {% endif %}
                            </div>

                            <div class="col-md-6">
                                <label for="venue_id" class="form-label">{{ trans('evadmin.crud.venue') }}</label>
                                <select id="venue_id" name="venue_id" required
                                        class="form-select{{ errors.venue_id is defined ? ' is-invalid' : '' }}">
                                    <option value="" selected disabled>{{ trans('evadmin.crud.select_venue') }}</option>
                                    {% for venue in venues %}
                                        <option value="{{ venue.id }}">{{ venue.name }}</option>
                                    {% endfor %}
                                </select>
                                {% if errors.venue_id is defined %}
                                    <div class="invalid-feedback">{{ errors.venue_id | first }}</div>
                                {% endif %}
                            </div>

                            <div class="col-md-6">
                                <label for="date" class="form-label">{{ trans('evadmin.crud.date') }}</label>
                                <input type="datetime-local" id="date" name="date" required
                                       class="form-control{{ errors.date is defined ? ' is-invalid' : '' }}"
                                       value="{{ input.date ?? '' }}">
                                {% if errors.date is defined %}
                                    <div class="invalid-feedback">{{ errors.date | first }}</div>
                                {% endif %}
                            </div>

                            <div class="col-md-6">
                                <label for="event_image" class="form-label">{{ trans('evadmin.crud.image') }}</label>
                                <input type="url" id="event_image" name="event_image" class="form-control" placeholder="{{ trans('ph.event_image') }}">
                            </div>

                            <div class="col-12">
                                <label for="description" class="form-label">{{ trans('evadmin.crud.description') }}</label>
                                <textarea id="description" name="description" required
                                          class="form-control{{ errors.description is defined ? ' is-invalid' : '' }}"
                                          rows="5"
                                          placeholder="{{ trans('ph.event_desc_full') }}">{{ input.description ?? '' }}</textarea>
                                {% if errors.description is defined %}
                                    <div class="invalid-feedback">{{ errors.description | first }}</div>
                                {% endif %}
                            </div>

                            <div class="col-12 mt-5 border-top pt-4">
                                <div class="d-flex gap-3">
                                    <button type="submit" class="btn btn-create flex-grow-1">
                                        <i class="bi bi-check-lg me-2"></i> {{ trans('evadmin.crud.create') }}
                                    </button>
                                    <a href="{{ base_path }}/events" class="btn btn-light btn-cancel border flex-grow-1 text-center">
                                        {{ trans('evadmin.crud.cancel') }}
                                    </a>
                                </div>
                            </div>

                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
