<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Event - TicketMaestrix</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="{{ base_path }}/css/forms.css">
    <style>
        :root {
            --brand-purple: #5E246E;
            --brand-dark: #371840;
            --accent-purple: #9b51e0;
            --bg-light: #F8F9FA;
        }
        body { background-color: var(--bg-light); font-family: 'Inter', sans-serif; }
        
        /* Consistent Banner Styling */
        .page-banner {
            background: linear-gradient(135deg, var(--brand-dark) 0%, var(--brand-purple) 100%);
            color: white;
            padding: 3rem 0;
            margin-bottom: 3rem;
        }

        /* Form Card Styling */
        .form-card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            background: white;
            padding: 2.5rem;
        }
        
        .form-label { 
            font-weight: 600; 
            font-size: 0.9rem; 
            color: #444;
            margin-bottom: 0.5rem;
        }
        
        .form-control, .form-select { 
            padding: 0.75rem; 
            border-radius: 8px; 
            border: 1px solid #dee2e6;
            transition: all 0.2s;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--accent-purple);
            box-shadow: 0 0 0 0.25rem rgba(155, 81, 224, 0.1);
            outline: none;
        }
        
        /* Button Styling */
        .btn-create {
            background-color: var(--accent-purple);
            border: none;
            color: white;
            padding: 0.8rem 2rem;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.2s;
        }
        .btn-create:hover { 
            background-color: #8339c9; 
            color: white;
            transform: translateY(-1px);
        }

        .btn-cancel {
            padding: 0.8rem 2rem;
            border-radius: 10px;
            font-weight: 600;
        }

        /* Navbar placeholder matching your admin dashboard */
        .navbar-placeholder {
            height: 60px;
            background: white;
            border-bottom: 1px solid #eee;
        }
    </style>
</head>
<body>

    <!-- If you have a real navbar, it would go here -->
    <div class="navbar-placeholder"></div>

    <!-- Header Banner -->
    <div class="page-banner">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold mb-1">Create New Event</h2>
                    <p class="mb-0 opacity-75">Fill in the details below to list your new event</p>
                </div>
                <a href="{{ base_path }}/events" class="btn btn-outline-light rounded-pill px-4">
                    <i class="bi bi-arrow-left me-2"></i> Back to Events
                </a>
            </div>
        </div>
    </div>

    <div class="container pb-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card form-card">
                    <form action="{{ base_path }}/events" method="post">
                        <div class="row g-4">
                            
                            <!-- Title -->
                            <div class="col-12">
                                <label for="title" class="form-label">Event Title *</label>
                                <input type="text" id="title" name="title" required
                                       class="form-control{{ errors.title is defined ? ' is-invalid' : '' }}"
                                       placeholder="e.g. Summer Music Festival"
                                       value="{{ input.title ?? '' }}">
                                {% if errors.title is defined %}
                                    <div class="invalid-feedback">{{ errors.title | first }}</div>
                                {% endif %}
                            </div>

                            <!-- Category & Venue -->
                            <div class="col-md-6">
                                <label for="category_id" class="form-label">Category *</label>
                                <select id="category_id" name="category_id" required
                                        class="form-select{{ errors.category_id is defined ? ' is-invalid' : '' }}">
                                    <option value="" selected disabled>— Select a category —</option>
                                    {% for category in categories %}
                                        <option value="{{ category.id }}">{{ category.name }}</option>
                                    {% endfor %}
                                </select>
                                {% if errors.category_id is defined %}
                                    <div class="invalid-feedback">{{ errors.category_id | first }}</div>
                                {% endif %}
                            </div>

                            <div class="col-md-6">
                                <label for="venue_id" class="form-label">Venue *</label>
                                <select id="venue_id" name="venue_id" required
                                        class="form-select{{ errors.venue_id is defined ? ' is-invalid' : '' }}">
                                    <option value="" selected disabled>— Select a venue —</option>
                                    {% for venue in venues %}
                                        <option value="{{ venue.id }}">{{ venue.name }}</option>
                                    {% endfor %}
                                </select>
                                {% if errors.venue_id is defined %}
                                    <div class="invalid-feedback">{{ errors.venue_id | first }}</div>
                                {% endif %}
                            </div>

                            <!-- Date -->
                            <div class="col-md-6">
                                <label for="date" class="form-label">Date & Time *</label>
                                <input type="datetime-local" id="date" name="date" required
                                       class="form-control{{ errors.date is defined ? ' is-invalid' : '' }}"
                                       value="{{ input.date ?? '' }}">
                                {% if errors.date is defined %}
                                    <div class="invalid-feedback">{{ errors.date | first }}</div>
                                {% endif %}
                            </div>

                            <!-- Image URL -->
                            <div class="col-md-6">
                                <label for="event_image" class="form-label">Image URL</label>
                                <input type="url" id="event_image" name="event_image" class="form-control" placeholder="https://example.com/image.jpg">
                            </div>

                            <!-- Description -->
                            <div class="col-12">
                                <label for="description" class="form-label">Description</label>
                                <textarea id="description" name="description" required
                                          class="form-control{{ errors.description is defined ? ' is-invalid' : '' }}"
                                          rows="5"
                                          placeholder="Provide a detailed description of the event...">{{ input.description ?? '' }}</textarea>
                                {% if errors.description is defined %}
                                    <div class="invalid-feedback">{{ errors.description | first }}</div>
                                {% endif %}
                            </div>

                            <!-- Form Actions -->
                            <div class="col-12 mt-5 border-top pt-4">
                                <div class="d-flex gap-3">
                                    <button type="submit" class="btn btn-create flex-grow-1">
                                        <i class="bi bi-check-lg me-2"></i> Create Event
                                    </button>
                                    <a href="{{ base_path }}/events" class="btn btn-light btn-cancel border flex-grow-1 text-center">
                                        Cancel
                                    </a>
                                </div>
                            </div>

                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>