{% extends "base.html.twig" %}

{% block title %}Events - TicketMaestrix{% endblock %}

{% block content %}
<div class="page-header">
    <h2>Events</h2>
    <a href="{{ base_path }}/events/create" class="btn btn-primary">Add New Event</a>
</div>

<div class="grid">
    {% for event in events %}
    <div class="card" data-name="{{ event.title|e('html_attr') }}">
        <div class="card-header">
            <h3>{{ event.title|e('html') }}</h3>
            <span class="team-badge">{{ event.date }}</span>
        </div>
        <div class="card-body">
            <p><strong>Description:</strong> {{ event.description|e('html') }}</p>
            <p><strong>Venue ID:</strong> {{ event.venue_id }}</p>
            <p><strong>Category ID:</strong> {{ event.category_id }}</p>
        </div>
        <div class="card-footer">
            <a href="{{ base_path }}/events/{{ event.id }}/edit" class="btn btn-secondary">Edit</a>
            <a href="{{ base_path }}/tickets/event/{{ event.id }}" class="btn btn-secondary">Tickets</a>
            <form action="{{ base_path }}/events/{{ event.id }}/delete" method="post" style="display:inline;">
                <button type="submit" class="btn btn-danger" onclick="return confirm('Delete this event?')">Delete</button>
            </form>
        </div>
    </div>
    {% else %}
    <div class="empty-state">
        <p>No events found. <a href="{{ base_path }}/events/create">Add the first event</a>.</p>
    </div>
    {% endfor %}
</div>
{% endblock %}
