<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Events by Category - TicketMaestrix</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root { --brand-purple: #5E246E; }
        body { background-color: #F8F9FA; }
        .event-card { border: none; border-radius: 12px; background: white; box-shadow: 0 4px 15px rgba(0,0,0,0.05); transition: transform 0.2s; }
        .event-card:hover { transform: translateY(-4px); }
        .event-img { height: 160px; background: linear-gradient(135deg, #371840, #5E246E); border-radius: 12px 12px 0 0; }
        .btn-brand { background-color: var(--brand-purple); color: white; font-size: 0.8rem; }
        .btn-brand:hover { background-color: #371840; color: white; }
    </style>
</head>
<body>
    {% include 'partials/navbar.html.twig' %}

    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <a href="{{ base_path }}/" class="text-decoration-none text-muted small">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
                <h4 class="fw-bold mb-0 mt-2">
                    <i class="bi bi-tag me-2" style="color:var(--brand-purple)"></i>
                    Events in Category #{{ category_id }}
                </h4>
            </div>
            <span class="text-muted small">{{ events|length }} event(s)</span>
        </div>

        {% if events is empty %}
        <div class="text-center py-5 text-muted">
            <i class="bi bi-calendar-x display-4 d-block mb-3"></i>
            No events found in this category.
        </div>
        {% else %}
        <div class="row g-4">
            {% for event in events %}
            <div class="col-md-4">
                <div class="event-card h-100">
                    <div class="event-img"></div>
                    <div class="p-3">
                        <h6 class="fw-bold mb-1">{{ event.title }}</h6>
                        <div class="text-muted small mb-1">
                            <i class="bi bi-calendar me-1"></i>{{ event.date }}
                        </div>
                        <div class="text-muted small mb-3">
                            <i class="bi bi-geo-alt me-1"></i>Venue #{{ event.venue_id }}
                        </div>
                        <a href="{{ base_path }}/events/{{ event.id }}" class="btn btn-brand btn-sm">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
