<!DOCTYPE html>
<html lang="{{ current_locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ event.title }} - {{ trans('app.title') }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --brand-purple: #5E246E;
            --brand-dark: #371840;
            --accent-purple: #9b51e0;
            --bg-light: #F8F9FA;
        }
        body { background-color: var(--bg-light); font-family: 'Inter', sans-serif; }

        /* Enhanced Hero Section */
        .event-hero {
            background: linear-gradient(135deg, var(--brand-dark) 0%, var(--brand-purple) 100%);
            color: white;
            padding: 4rem 0;
            position: relative;
            overflow: hidden;
        }

        /* Subtle background decoration */
        .event-hero::after {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 400px;
            height: 400px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 50%;
        }

        .back-link {
            transition: transform 0.2s;
            display: inline-block;
        }
        .back-link:hover {
            transform: translateX(-5px);
            opacity: 1 !important;
        }

        .event-image-container {
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            border: 4px solid rgba(255, 255, 255, 0.1);
            transition: transform 0.3s ease;
        }
        .event-image-container:hover {
            transform: scale(1.02);
        }

        /* Information Chips */
        .info-chip {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            padding: 0.5rem 1rem;
            border-radius: 50px;
            font-size: 0.85rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Content Card */
        .content-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            margin-top: -30px; /* Overlaps hero slightly */
            background: white;
            z-index: 10;
            position: relative;
        }

        .btn-brand {
            background-color: var(--accent-purple);
            border: none;
            color: white;
            padding: 0.8rem 2rem;
            border-radius: 12px;
            font-weight: 600;
            transition: all 0.2s;
        }
        .btn-brand:hover {
            background-color: #8339c9;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(155, 81, 224, 0.3);
        }

        .btn-outline-danger {
            border-radius: 12px;
            padding: 0.8rem 1.5rem;
            border: 2px solid #dc3545;
            font-weight: 600;
        }
    </style>
</head>
<body>

    {% include 'partials/navbar.html.twig' %}

    <div class="event-hero">
        <div class="container" style="max-width: 900px;">
            <a href="{{ base_path }}/" class="text-white text-decoration-none small opacity-75 back-link mb-4">
                <i class="bi bi-arrow-left"></i> {{ trans('evdetails.back') }}
            </a>

            <div class="row align-items-center g-4">
                {% if event.event_image %}
                <div class="col-md-5">
                    <img src="{{ event.event_image }}" alt="{{ event.title }}"
                         class="w-100 rounded-4 event-image-container" style="aspect-ratio: 1/1; object-fit: cover;">
                </div>
                {% endif %}

                <div class="{% if event.event_image %}col-md-7{% else %}col-12{% endif %}">
                    <span class="badge bg-white text-dark mb-2 px-3 py-2 rounded-pill">{{ trans('evdetails.featured') }}</span>
                    <h1 class="display-5 fw-bold mb-3">{{ event.title }}</h1>

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <div class="info-chip">
                            <i class="bi bi-calendar3 me-2 text-info"></i>{{ event.date }}
                        </div>
                        <div class="info-chip">
                            <i class="bi bi-geo-alt me-2 text-warning"></i>{{ event.venue_name ?: 'Venue #' ~ event.venue_id }}
                        </div>
                        <div class="info-chip">
                            <i class="bi bi-tag me-2 text-success"></i>{{ event.category ?: 'Category #' ~ event.category_id }}
                        </div>
                        {% if event.min_price is defined and event.min_price %}
                        <div class="info-chip">
                            <i class="bi bi-currency-dollar me-2 text-success"></i>From ${{ event.min_price|number_format(2) }}
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container py-5" style="max-width: 900px;">
        <div class="card content-card p-4 p-md-5 mb-5">
            <div class="row">
                <div class="col-12">
                    <h4 class="fw-bold mb-4">{{ trans('evdetails.header') }}</h4>
                    <div class="text-muted lh-lg">
                        {{ event.description ?: trans('evdetails.no_desc') }}
                    </div>
                </div>
            </div>

            <hr class="my-5 opacity-25">

            <div class="d-flex flex-column flex-md-row gap-3">
                <a href="{{ base_path }}/tickets/event/{{ event.id }}" class="btn btn-brand btn-lg flex-grow-1 d-flex align-items-center justify-content-center">
                    <i class="bi bi-ticket-perforated-fill me-2"></i> {{ trans('evdetails.button') }}
                </a>

                {% if is_admin is defined and is_admin %}
                <div class="d-flex gap-3 w-100">
                    <a href="{{ base_path }}/events/{{ event.id }}/edit" class="btn btn-outline-primary btn-lg flex-grow-1 d-flex align-items-center justify-content-center">
                        <i class="bi bi-pencil-square me-1"></i> {{ trans('evdetails.edit_btn') }}
                    </a>
                    <form action="{{ base_path }}/events/{{ event.id }}/delete" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-outline-danger btn-lg"
                                onclick="return confirm('{{ trans('confirm.delete_event')|e('js') }}')">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </form>
                </div>
                {% endif %}
            </div>
        </div>

        <!-- Footer Note -->
        <div class="text-center text-muted small mt-4">
            <p><i class="bi bi-shield-check me-1"></i> {{ trans('evdetails.message') }}</p>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
