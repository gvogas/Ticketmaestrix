<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ event.title }} - TicketMaestrix</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root { --brand-purple: #5E246E; }
        body { background-color: #F8F9FA; }
        .event-hero {
            background: linear-gradient(135deg, #371840 0%, #5E246E 100%);
            color: white;
            padding: 3rem 0;
        }
        .btn-brand { background-color: var(--brand-purple); color: white; }
        .btn-brand:hover { background-color: #371840; color: white; }
    </style>
</head>
<body>
    {% include 'partials/navbar.html.twig' %}

    <div class="event-hero">
        <div class="container" style="max-width: 800px;">
            <a href="{{ base_path }}/" class="text-white text-decoration-none small opacity-75">
                <i class="bi bi-arrow-left"></i> Back to Events
            </a>
            {% if event.event_image %}
            <img src="{{ event.event_image }}" alt="{{ event.title }}"
                 class="w-100 rounded-4 mt-3 mb-4" style="max-height:320px;object-fit:cover;">
            {% endif %}
            <h1 class="fw-bold mt-3">{{ event.title }}</h1>
            <div class="d-flex flex-wrap gap-3 mt-2 opacity-75 small">
                <span><i class="bi bi-calendar me-1"></i>{{ event.date }}</span>
                <span><i class="bi bi-geo-alt me-1"></i>Venue #{{ event.venue_id }}</span>
                <span><i class="bi bi-tag me-1"></i>Category #{{ event.category_id }}</span>
            </div>
        </div>
    </div>

    <div class="container py-5" style="max-width: 800px;">
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <h5 class="fw-bold mb-3">About this event</h5>
            <p class="text-muted mb-0">{{ event.description ?: 'No description provided.' }}</p>
        </div>

        <div class="d-flex gap-2">
            <a href="{{ base_path }}/tickets/event/{{ event.id }}" class="btn btn-brand">
                <i class="bi bi-ticket-perforated me-1"></i> View Tickets
            </a>
            <form action="{{ base_path }}/events/{{ event.id }}/delete" method="POST" class="d-inline">
                <button type="submit" class="btn btn-outline-danger"
                        onclick="return confirm('Delete this event?')">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
