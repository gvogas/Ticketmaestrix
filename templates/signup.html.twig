<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TicketMaestrix - Signup</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body {
            background: linear-gradient(135deg, #a060a8 0%, #4a215d 100%);
            min-height: 100vh;
            margin: 0;
        }
        
        .signup-container {
            max-width: 500px; 
            width: 100%;
        }

        .logo-circle {
            width: 60px;
            height: 60px;
            background-color: white;
            color: #7b2cbf;
            font-size: 30px;
        }

        .btn-signup {
            background-color: #5E246E;
            color: white !important;
            border: none;
            padding: 0.8rem;
            font-size: 1.1rem;
            transition: background-color 0.3s ease;
        }

        .btn-signup:hover {
            background-color: #371840;
            color: white !important;
        }

        .bi-google { color: #DB4437; } 
        .bi-facebook { color: #1877F2; } 

        .text-purple {
            color: #7b2cbf;
            text-decoration: none;
            font-weight: 600;
        }

        .form-control, .btn, .input-group-text {
            padding: 0.8rem 1rem;
            font-size: 1.1rem;
        }
    </style>
</head>
<body class="d-flex flex-column align-items-center justify-content-center p-3">

    <div class="text-center text-white mb-4">
        <div class="logo-circle rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow">
            <i class="bi bi-ticket-perforated-fill"></i>
        </div>
        <h1 class="fw-bold display-5">Join TicketMaestrix</h1>
        <p class="fs-5 opacity-75">Create your account and start exploring events</p>
    </div>

    <div class="card signup-container shadow-lg border-0 rounded-4 p-5">
        <form action="/signup" method="POST">
            
            <div class="mb-4">
                <label class="form-label fw-bold">Full Name</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-person"></i></span>
                    <input type="text" name="fullname" class="form-control border-start-0" placeholder="John Doe" required>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Email Address</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-envelope"></i></span>
                    <input type="email" name="email" class="form-control border-start-0" placeholder="john@example.com" required>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Password</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-lock"></i></span>
                    <input type="password" name="password" class="form-control border-start-0" placeholder="••••••••" required>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Confirm Password</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-lock-fill"></i></span>
                    <input type="password" name="password2" class="form-control border-start-0" placeholder="••••••••" required>
                </div>
            </div>

            <div class="mb-4 fs-6">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="terms" name="terms" required>
                    <label class="form-check-label text-muted" for="terms">
                        I agree to the <a href="#" class="text-purple">Terms</a> and <a href="#" class="text-purple">Privacy Policy</a>
                    </label>
                </div>
            </div>

            <button type="submit" class="btn btn-signup w-100 fw-bold mb-4 shadow">Create Account</button>

            <div class="text-center text-muted mb-4">Or sign up with</div>

            <div class="row g-3 mb-4">
                <div class="col-6">
                    <button type="button" class="btn btn-outline-light border text-dark w-100 d-flex align-items-center justify-content-center gap-2 py-2 shadow-sm">
                        <i class="bi bi-google"></i> Google
                    </button>
                </div>
                <div class="col-6">
                    <button type="button" class="btn btn-outline-light border text-dark w-100 d-flex align-items-center justify-content-center gap-2 py-2 shadow-sm">
                        <i class="bi bi-facebook"></i> Facebook
                    </button>
                </div>
            </div>

            <div class="text-center fs-6">
                Already have an account? <a href="/Ticketmaestrix/login" class="text-purple">Login</a>
            </div>
            
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>