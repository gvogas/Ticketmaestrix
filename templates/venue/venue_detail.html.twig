{% extends "layout.html.twig" %}
{% block title %}{{ venue.name }} - {{ trans('app.title') }}{% endblock %}
{% block head %}
<style>
    /* Venue Detail Card */
    .detail-container {
        max-width: 900px;
        margin: 0 auto 5rem auto;
    }

    .venue-hero-display {
        height: 350px;
        width: 100%;
        object-fit: cover;
        border-radius: 24px;
        background: linear-gradient(135deg, #371840, #5E246E);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        margin-bottom: -60px;
        position: relative;
        z-index: 1;
    }

    .venue-content-card {
        background: white;
        border-radius: 24px;
        padding: 80px 40px 40px 40px;
        border: 1px solid var(--border-color);
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        position: relative;
    }

    .info-pill {
        background: var(--bg-light);
        border: 1px solid var(--border-color);
        padding: 12px 20px;
        border-radius: 15px;
        height: 100%;
    }

    .label-text {
        font-size: 0.75rem;
        text-transform: uppercase;
        font-weight: 700;
        color: #94a3b8;
        letter-spacing: 0.05em;
        display: block;
        margin-bottom: 4px;
    }

    .value-text {
        font-weight: 600;
        color: #1e293b;
        font-size: 1.1rem;
    }

    .venue-description {
        line-height: 1.6;
        color: #475569;
        font-size: 1.1rem;
    }
</style>
{% endblock %}
{% block content %}

    <div class="container">

        <!-- Header -->
        <header class="admin-header">
            <div class="row align-items-center">
                <div class="col-lg-5">
                    <a href="{{ base_path }}/venues" class="text-decoration-none text-muted fw-600 mb-2 d-inline-block">
                        <i class="bi bi-arrow-left"></i> {{ trans('vadmin.back_venues') }}
                    </a>
                    <h1 class="fw-800 h2 mb-0">{{ trans('vadmin.details_header') }}</h1>
                </div>
                <div class="col-lg-7 text-lg-end mt-3 mt-lg-0">
                    <div class="d-flex gap-2 justify-content-lg-end flex-wrap">
                        <a href="{{ base_path }}/categories" class="btn-mgmt">
                            <i class="bi bi-tags-fill me-2"></i> {{ trans('evadmin.cat') }}
                        </a>
                        <a href="{{ base_path }}/events" class="btn-mgmt">
                            <i class="bi bi-calendar-event me-2"></i> {{ trans('evadmin.events') }}
                        </a>
                        <a href="{{ base_path }}/tickets" class="btn-mgmt">
                            <i class="bi bi-ticket-perforated me-2"></i> {{ trans('evadmin.tickets') }}
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <div class="detail-container">
            <!-- Hero Image/Icon -->
            {% if venue.image_url %}
                <img src="{{ venue.image_url }}" alt="{{ venue.name }}" class="venue-hero-display">
            {% else %}
                <div class="venue-hero-display">
                    <i class="bi bi-building-fill text-white opacity-25" style="font-size: 8rem;"></i>
                </div>
            {% endif %}

            <!-- Content Card -->
            <div class="venue-content-card">
                <div class="row g-4">
                    <div class="col-12 text-center mb-4">
                        <h2 class="display-6 fw-800 mb-2">{{ venue.name }}</h2>
                        <span class="badge bg-purple-soft px-3 py-2 rounded-pill" style="background: #f3e8ff; color: var(--brand-purple);">
                            <i class="bi bi-shield-check me-1"></i> {{ trans('vadmin.verified') }}
                        </span>
                    </div>

                    <div class="col-md-6">
                        <div class="info-pill">
                            <span class="label-text">{{ trans('vadmin.phys_address') }}</span>
                            <div class="value-text">
                                <i class="bi bi-geo-alt-fill me-2 text-muted"></i>{{ venue.address ?: trans('vadmin.no_address') }}
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="info-pill">
                            <span class="label-text">{{ trans('vadmin.max_capacity') }}</span>
                            <div class="value-text">
                                <i class="bi bi-people-fill me-2 text-muted"></i>{{ venue.capacity|number_format ?: '—' }} {{ trans('vadmin.seats') }}
                            </div>
                        </div>
                    </div>

                    <div class="col-12 mt-5">
                        <span class="label-text">{{ trans('vadmin.about') }}</span>
                        <p class="venue-description">
                            {{ venue.description ?: trans('vadmin.no_desc') }}
                        </p>
                    </div>

                    <!-- Footer Actions -->
                    <div class="col-12 mt-5 pt-4 border-top">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex gap-2">
                                <a href="{{ base_path }}/venues/{{ venue.id }}/edit" class="btn btn-dark px-4 py-2 fw-bold" style="border-radius: 12px;">
                                    <i class="bi bi-pencil-square me-2"></i> {{ trans('vadmin.edit_btn') }}
                                </a>
                            </div>

                            <form action="{{ base_path }}/venues/{{ venue.id }}/delete" method="POST"
                                  onsubmit="return confirm('{{ trans('confirm.delete_venue')|e('js') }}')">
                                <button type="submit" class="btn btn-outline-danger px-4 py-2 fw-bold" style="border-radius: 12px;">
                                    <i class="bi bi-trash3 me-2"></i> {{ trans('vadmin.delete_btn') }}
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
