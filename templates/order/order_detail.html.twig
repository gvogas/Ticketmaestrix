<!DOCTYPE html>
<html lang="{{ current_locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ trans('order.order_label') }} #{{ order.id }} - {{ trans('app.title') }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root { --brand-purple: #5E246E; }
        body { background-color: #F8F9FA; }
        .status-badge { font-size: 0.75rem; padding: 0.3rem 0.8rem; border-radius: 50px; }
    </style>
</head>
<body>
    {% include 'partials/navbar.html.twig' %}

    <div class="container py-5" style="max-width: 680px;">
        <a href="{{ base_path }}/orders/user/{{ order.user_id }}" class="text-decoration-none text-muted small mb-4 d-inline-block">
            <i class="bi bi-arrow-left"></i> {{ trans('order.back') }}
        </a>

        <div class="card border-0 shadow-sm rounded-4 p-4">
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div>
                    <h4 class="fw-bold mb-0">{{ trans('order.order_label') }} #{{ order.id }}</h4>
                    <small class="text-muted">{{ order.order_time }}</small>
                </div>
                {% if order.status == 1 %}
                    <span class="badge bg-success status-badge">{{ trans('order.status_completed') }}</span>
                {% elseif order.status == 0 %}
                    <span class="badge bg-warning text-dark status-badge">{{ trans('order.status_pending') }}</span>
                {% else %}
                    <span class="badge bg-secondary status-badge">Status {{ order.status }}</span>
                {% endif %}
            </div>

            <ul class="list-group list-group-flush mb-4">
                <li class="list-group-item px-0">
                    <i class="bi bi-person me-2 text-muted"></i>
                    <strong>{{ trans('order.user_id') }}:</strong> {{ order.user_id }}
                </li>
                <li class="list-group-item px-0">
                    <i class="bi bi-currency-dollar me-2 text-muted"></i>
                    <strong>{{ trans('order.total') }}:</strong>
                    <span class="fw-bold" style="color:var(--brand-purple)">${{ order.total_price }}</span>
                </li>
            </ul>

            <a href="{{ base_path }}/order-items/order/{{ order.id }}" class="btn btn-sm btn-outline-secondary me-2">
                <i class="bi bi-list-ul"></i> {{ trans('order.view_items') }}
            </a>
            <form action="{{ base_path }}/orders/{{ order.id }}/delete" method="POST" class="d-inline">
                <button type="submit" class="btn btn-sm btn-outline-danger"
                        onclick="return confirm('{{ trans('confirm.delete_order')|e('js') }}')">
                    <i class="bi bi-trash"></i> {{ trans('order.delete') }}
                </button>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
