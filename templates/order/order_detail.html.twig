{% extends "layout.html.twig" %}
{% block title %}{{ trans('order.order_label') }} #{{ order.id }} - {{ trans('app.title') }}{% endblock %}
{% block head %}
<style>
    body { background-color: #F8F9FA; }
    .status-badge { font-size: 0.75rem; padding: 0.3rem 0.8rem; border-radius: 50px; }
</style>
{% endblock %}
{% block content %}

    <div class="container py-5" style="max-width: 680px;">
        <a href="{{ base_path }}/orders/user/{{ order.user_id }}" class="text-decoration-none text-muted small mb-4 d-inline-block">
            <i class="bi bi-arrow-left"></i> {{ trans('order.back') }}
        </a>

        <div class="card border-0 shadow-sm rounded-4 p-4">
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div>
                    <h4 class="fw-bold mb-0">{{ trans('order.order_label') }} #{{ order.id }}</h4>
                    <small class="text-muted">{{ order.order_time }}</small>
                </div>
                {% if order.status == 1 %}
                    <span class="badge bg-success status-badge">{{ trans('order.status_completed') }}</span>
                {% elseif order.status == 0 %}
                    <span class="badge bg-warning text-dark status-badge">{{ trans('order.status_pending') }}</span>
                {% else %}
                    <span class="badge bg-secondary status-badge">Status {{ order.status }}</span>
                {% endif %}
            </div>

            <ul class="list-group list-group-flush mb-4">
                <li class="list-group-item px-0">
                    <i class="bi bi-person me-2 text-muted"></i>
                    <strong>{{ trans('order.customer') }}:</strong> {{ customer_name ?: order.user_id }}
                </li>
                <li class="list-group-item px-0">
                    <i class="bi bi-currency-dollar me-2 text-muted"></i>
                    <strong>{{ trans('order.total') }}:</strong>
                    <span class="fw-bold" style="color:var(--brand-purple)">${{ order.total_price }}</span>
                </li>
            </ul>

            <a href="{{ base_path }}/order-items/order/{{ order.id }}" class="btn btn-sm btn-outline-secondary me-2">
                <i class="bi bi-list-ul"></i> {{ trans('order.view_items') }}
            </a>
            <button type="button" class="btn btn-sm btn-outline-danger"
                    data-bs-toggle="modal" data-bs-target="#deleteOrderModal">
                <i class="bi bi-trash"></i> {{ trans('order.delete') }}
            </button>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteOrderModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow">
                <div class="modal-header border-0 pt-4 px-4">
                    <h5 class="fw-bold text-danger">{{ trans('order.delete') }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body px-4 pb-4">
                    <p class="mb-0">{{ trans('confirm.delete_order') }}</p>
                </div>
                <div class="modal-footer border-0 pb-4 px-4">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">{{ trans('evadmin.crud.cancel') }}</button>
                    <form action="{{ base_path }}/orders/{{ order.id }}/delete" method="POST" class="m-0">
                        <button type="submit" class="btn btn-danger px-4">{{ trans('order.delete') }}</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
