<!DOCTYPE html>
<html lang="{{ current_locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ trans('order.my_orders') }} - {{ trans('app.title') }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root { --brand-purple: #5E246E; }
        body { background-color: #F8F9FA; }
    </style>
</head>
<body>
    {% include 'partials/navbar.html.twig' %}

    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold mb-0">
                <i class="bi bi-receipt me-2" style="color:var(--brand-purple)"></i>
                {{ trans('order.my_orders') }}
            </h4>
            <span class="text-muted small">{{ orders|length }} order(s)</span>
        </div>

        {% if orders is empty %}
        <div class="text-center py-5 text-muted">
            <i class="bi bi-bag-x display-4 d-block mb-3"></i>
            {{ trans('order.no_orders') }}
        </div>
        {% else %}
        <div class="d-flex flex-column gap-3">
            {% for order in orders %}
            <div class="card border-0 shadow-sm rounded-4 p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fw-bold">{{ trans('order.order_label') }} #{{ order.id }}</div>
                        <small class="text-muted">{{ order.order_time }}</small>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <span class="fw-bold" style="color:var(--brand-purple)">${{ order.total_price }}</span>
                        {% if order.status == 1 %}
                            <span class="badge bg-success">{{ trans('order.status_completed') }}</span>
                        {% else %}
                            <span class="badge bg-warning text-dark">{{ trans('order.status_pending') }}</span>
                        {% endif %}
                        <a href="{{ base_path }}/orders/{{ order.id }}" class="btn btn-sm btn-outline-secondary">
                            {{ trans('order.view') }}
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
