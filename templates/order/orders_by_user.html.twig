{% extends "layout.html.twig" %}
{% block title %}{{ trans('order.my_orders') }} - {{ trans('app.title') }}{% endblock %}
{% block head %}
<style>
    body { background-color: #F8F9FA; }
</style>
{% endblock %}
{% block content %}

    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold mb-0">
                <i class="bi bi-receipt me-2" style="color:var(--brand-purple)"></i>
                {{ trans('order.my_orders') }}
            </h4>
            <span class="text-muted small">{{ total_orders|default(orders|length) }} order(s)</span>
        </div>

        {% if orders is empty %}
        <div class="text-center py-5 text-muted">
            <i class="bi bi-bag-x display-4 d-block mb-3"></i>
            {{ trans('order.no_orders') }}
        </div>
        {% else %}
        <div class="d-flex flex-column gap-3">
            {% for order in orders %}
            <div class="card border-0 shadow-sm rounded-4 p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fw-bold">{{ trans('order.order_label') }} #{{ order.id }}</div>
                        <small class="text-muted">{{ order.order_time }}</small>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <span class="fw-bold" style="color:var(--brand-purple)">${{ order.total_price }}</span>
                        {% if order.status == 1 %}
                            <span class="badge bg-success">{{ trans('order.status_completed') }}</span>
                        {% else %}
                            <span class="badge bg-warning text-dark">{{ trans('order.status_pending') }}</span>
                        {% endif %}
                        <a href="{{ base_path }}/orders/{{ order.id }}" class="btn btn-sm btn-outline-secondary">
                            {{ trans('order.view') }}
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>

        {% include 'partials/pagination.html.twig' with {
            current_page: current_page,
            total_pages:  total_pages,
            base_url:     base_path ~ '/orders/user/' ~ user_id,
            query_params: query_params
        } only %}
        {% endif %}
    </div>

{% endblock %}
