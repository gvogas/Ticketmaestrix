<!DOCTYPE html>
<html lang="{{ current_locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ trans('app.title') }}{% endblock %}</title>
    <link rel="stylesheet" href="{{ base_path }}/assets/css/style.css">
</head>
<body>
    <header>
        <nav>
            <div class="nav-container">
                <h1><a href="{{ base_path }}/">{{ trans('app.title') }}</a></h1>
                <ul class="nav-links">
                    <li><a href="{{ base_path }}/events">{{ trans('app.events') }}</a></li>
                    <li><a href="{{ base_path }}/categories">{{ trans('app.categories') }}</a></li>
                    <li><a href="{{ base_path }}/venues">{{ trans('app.venues') }}</a></li>
                    <li><a href="{{ base_path }}/tickets">{{ trans('app.tickets') }}</a></li>
                    <li><a href="{{ base_path }}/admin">{{ trans('app.admin') }}</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <main>
        <div class="container">
            {% block content %}{% endblock %}
        </div>
    </main>

    <footer>
        <div class="container">
            <p>&copy; 2026 {{ trans('app.title') }}. {{ trans('footer.rights') }}</p>
        </div>
    </footer>
</body>
</html>
