{# ──────────────────────────────────────────────
   partials/event-card.html.twig
   
   Expected variables:
     event.id          — int
     event.title       — string
     event.category    — string (Concert, Movies, Sports, Theater, Raffle, Festival)
     event.image       — string (URL or path)
     event.date        — string (formatted date)
     event.venue       — string
     event.tickets     — int (available count)
     event.price       — float
     event.original_price — float|null (strikethrough price)
     event.badge       — string|null  (e.g. "SALE", "ON SALE", "TOP SALE")
     event.badge_right — string|null  (e.g. "TICKETS")
     show_badge        — bool (default true)
   ────────────────────────────────────────────── #}

{% set cat_colors = {
    'Concert':  'bg-purple-100 text-purple-700',
    'Movies':   'bg-indigo-100 text-indigo-700',
    'Sports':   'bg-blue-100 text-blue-700',
    'Theater':  'bg-pink-100 text-pink-700',
    'Raffle':   'bg-amber-100 text-amber-700',
    'Festival': 'bg-green-100 text-green-700'
} %}

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm hover:shadow-md transition group">
    {# Image #}
    <div class="relative overflow-hidden">
        <img
            src="{{ event.image }}"
            alt="{{ event.title }}"
            class="aspect-video w-full object-cover group-hover:scale-105 transition duration-300"
            loading="lazy"
        >

        {% if show_badge|default(true) %}
            {% if event.badge %}
                <span class="absolute top-3 left-3 bg-red-500 text-white text-xs font-semibold px-2 py-0.5 rounded shadow">
                    {{ event.badge }}
                </span>
            {% endif %}
            {% if event.badge_right is defined and event.badge_right %}
                <span class="absolute top-3 right-3 bg-purple-600 text-white text-xs font-semibold px-2 py-0.5 rounded shadow">
                    {{ event.badge_right }}
                </span>
            {% endif %}
        {% endif %}
    </div>

    {# Details #}
    <div class="p-4">
        <span class="inline-block text-xs font-semibold uppercase tracking-wide px-2 py-0.5 rounded {{ cat_colors[event.category] ?? 'bg-gray-100 text-gray-700' }}">
            {{ event.category }}
        </span>

        <h3 class="font-semibold text-gray-900 mt-2 line-clamp-1">{{ event.title }}</h3>

        <div class="mt-2 space-y-0.5">
            <p class="text-xs text-gray-500">📅 {{ event.date }}</p>
            <p class="text-xs text-gray-500">📍 {{ event.venue }}</p>
            {% if event.tickets is defined %}
                <p class="text-xs text-gray-500">🎫 {{ event.tickets }} tickets available</p>
            {% endif %}
        </div>

        <div class="flex items-center justify-between mt-3">
            <div>
                <span class="text-lg font-bold text-gray-900">${{ event.price|number_format(2) }}</span>
                {% if event.original_price is defined and event.original_price %}
                    <span class="text-xs text-gray-400 line-through ml-1">${{ event.original_price|number_format(2) }}</span>
                {% endif %}
            </div>
            <a
                href="{{ base_path }}/events/{{ event.id }}"
                class="bg-purple-600 hover:bg-purple-700 text-white text-xs font-semibold px-4 py-2 rounded-lg transition"
            >
                View Details
            </a>
        </div>
    </div>
</div>
