{% extends "base.html.twig" %}

{% block title %}Create Category - TicketMaestrix{% endblock %}

{% block content %}
<div class="page-header">
    <h2>Create New Category</h2>
    <a href="{{ base_path }}/categories" class="btn btn-secondary">Back to Categories</a>
</div>

<form action="{{ base_path }}/categories" method="post" class="form">
    <div class="form-group">
        <label for="name">Category Name:</label>
        <input type="text" id="name" name="name" required>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Create Category</button>
        <a href="{{ base_path }}/categories" class="btn btn-secondary">Cancel</a>
    </div>
</form>
{% endblock %}
