<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ category.name }} - TicketMaestrix</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root { --brand-purple: #5E246E; }
        body { background-color: #F8F9FA; }
    </style>
</head>
<body>
    {% include 'partials/navbar.html.twig' %}

    <div class="container py-5" style="max-width: 640px;">
        <a href="{{ base_path }}/" class="text-decoration-none text-muted small mb-4 d-inline-block">
            <i class="bi bi-arrow-left"></i> Back
        </a>

        <div class="card border-0 shadow-sm rounded-4 p-4">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:56px;height:56px;background:#5E246E;">
                    <i class="bi bi-tag-fill text-white fs-4"></i>
                </div>
                <div>
                    <h4 class="fw-bold mb-0">{{ category.name }}</h4>
                    <small class="text-muted">Category #{{ category.id }}</small>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <a href="{{ base_path }}/events/category/{{ category.id }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-ticket-perforated"></i> View Events
                </a>
                <form action="{{ base_path }}/categories/{{ category.id }}/delete" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-outline-danger"
                            onclick="return confirm('Delete this category?')">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
