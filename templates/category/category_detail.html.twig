<!DOCTYPE html>
<html lang="{{ current_locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ category.name }} - {{ trans('app.title') }}</title>

    <!-- Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');

        :root {
            --brand-purple: #5E246E;
            --brand-hover: #4a1d56;
            --bg-light: #f8fafc;
            --border-color: #e2e8f0;
        }

        body {
            background-color: #ffffff;
            font-family: 'Inter', sans-serif;
            color: #1a202c;
        }

        /* Admin Header Section */
        .admin-header {
            padding: 3rem 0 2rem 0;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 3rem;
        }

        .btn-mgmt {
            background: white;
            border: 1px solid var(--border-color);
            color: #4a5568;
            font-weight: 600;
            border-radius: 10px;
            padding: 10px 20px;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

        .btn-mgmt:hover {
            border-color: var(--brand-purple);
            color: var(--brand-purple);
            background: #fdfaff;
        }

        /* Category Detail Card */
        .detail-container {
            max-width: 700px;
            margin: 0 auto 5rem auto;
        }

        .category-profile-header {
            background: var(--brand-purple);
            height: 160px;
            border-radius: 24px 24px 0 0;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .category-icon-circle {
            width: 100px;
            height: 100px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            position: absolute;
            bottom: -50px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            border: 4px solid white;
        }

        .content-card {
            background: white;
            border-radius: 0 0 24px 24px;
            padding: 70px 40px 40px 40px;
            border: 1px solid var(--border-color);
            border-top: none;
            text-align: center;
        }

        .category-id-pill {
            display: inline-block;
            background: var(--bg-light);
            border: 1px solid var(--border-color);
            padding: 4px 16px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 700;
            color: #64748b;
            margin-bottom: 1rem;
        }
    </style>
</head>
<body>

    {% include 'partials/navbar.html.twig' %}

    <div class="container">

        <!-- Header -->
        <header class="admin-header">
            <div class="row align-items-center">
                <div class="col-lg-5">
                    <a href="{{ base_path }}/categories" class="text-decoration-none text-muted fw-600 mb-2 d-inline-block">
                        <i class="bi bi-arrow-left"></i> {{ trans('catadmin.back_cats') }}
                    </a>
                    <h1 class="fw-800 h2 mb-0">{{ trans('catadmin.profile') }}</h1>
                </div>
                <div class="col-lg-7 text-lg-end mt-3 mt-lg-0">
                    <div class="d-flex gap-2 justify-content-lg-end flex-wrap">
                        <a href="{{ base_path }}/events" class="btn-mgmt">
                            <i class="bi bi-calendar-event me-2"></i> {{ trans('evadmin.events') }}
                        </a>
                        <a href="{{ base_path }}/tickets" class="btn-mgmt">
                            <i class="bi bi-ticket-perforated me-2"></i> {{ trans('evadmin.tickets') }}
                        </a>
                        <a href="{{ base_path }}/venues" class="btn-mgmt">
                            <i class="bi bi-building me-2"></i> {{ trans('evadmin.venue') }}
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <div class="detail-container">
            <!-- Visual Header -->
            <div class="category-profile-header">
                <div class="category-icon-circle">
                    <i class="bi bi-tags-fill" style="font-size: 2.5rem; color: var(--brand-purple);"></i>
                </div>
            </div>

            <!-- Content -->
            <div class="content-card">
                <span class="category-id-pill">{{ trans('catadmin.db_id') }}: #{{ category.id }}</span>
                <h2 class="display-6 fw-800 mb-4">{{ category.name }}</h2>

                <div class="d-flex justify-content-center gap-3 mb-5">
                    <a href="{{ base_path }}/events/category/{{ category.id }}" class="btn btn-purple px-4 py-2" style="background-color: var(--brand-purple); color: white; border-radius: 12px; text-decoration: none; font-weight: 600;">
                        <i class="bi bi-ticket-perforated me-2"></i> {{ trans('catadmin.view_events') }}
                    </a>
                </div>

                <!-- Footer Actions -->
                <div class="pt-4 border-top">
                    <div class="d-flex justify-content-between align-items-center">
                        <a href="{{ base_path }}/categories/{{ category.id }}/edit" class="btn btn-dark px-4 py-2 fw-bold" style="border-radius: 12px;">
                            <i class="bi bi-pencil-square me-2"></i> {{ trans('catadmin.edit_name') }}
                        </a>

                        <form action="{{ base_path }}/categories/{{ category.id }}/delete" method="POST"
                              onsubmit="return confirm('{{ trans('confirm.delete_category')|e('js') }}')">
                            <button type="submit" class="btn btn-outline-danger px-4 py-2 fw-bold" style="border-radius: 12px;">
                                <i class="bi bi-trash3 me-2"></i> {{ trans('catadmin.delete_cat') }}
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
