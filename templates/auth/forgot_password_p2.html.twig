{% extends "layout.html.twig" %}
{% block title %}{{ trans('app.title') }} - {{ trans('verify.header') }}{% endblock %}
{% block navbar %}{% endblock %}
{% block head %}
<style>
    body {
        background: linear-gradient(135deg, #a060a8 0%, #4a215d 100%);
        min-height: 100vh;
        margin: 0;
    }

    main {
        align-self: stretch;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .verify-container {
        max-width: 500px;
        width: 100%;
    }

    .logo-circle {
        width: 60px;
        height: 60px;
        background-color: white;
        color: #7b2cbf;
        font-size: 30px;
    }

    .code-input {
        width: 50px;
        height: 60px;
        text-align: center;
        font-size: 1.5rem;
        font-weight: bold;
        border: 2px solid #dee2e6;
        border-radius: 12px;
    }

    .code-input:focus {
        border-color: #5E246E;
        outline: none;
        box-shadow: 0 0 0 0.25rem rgba(123, 44, 191, 0.25);
    }

    .btn-continue {
        background-color: #5E246E;
        color: white !important;
        border: none;
        padding: 0.8rem;
        font-size: 1.1rem;
        transition: background-color 0.3s ease;
    }

    .btn-continue:hover {
        background-color: #371840;
        color: white !important;
    }

    .text-purple {
        color: #7b2cbf;
        text-decoration: none;
        font-weight: 600;
    }
</style>
{% endblock %}
{% block content %}

    <div class="text-center text-white mb-4">
        <div class="logo-circle rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow">
            <i class="bi bi-patch-check-fill"></i>
        </div>
        <h1 class="fw-bold display-5">{{ trans('verify.header') }}</h1>
        <p class="fs-5 opacity-75">{{ trans('verify.subheader') }}</p>
    </div>

    <div class="card verify-container shadow-lg border-0 rounded-4 p-5 text-center">
        <form action="/verificationcode" method="POST">

            <div class="d-flex justify-content-center gap-2 mb-4">
                <input type="text" class="code-input" maxlength="1" inputmode="numeric" required>
                <input type="text" class="code-input" maxlength="1" inputmode="numeric" required>
                <input type="text" class="code-input" maxlength="1" inputmode="numeric" required>
                <input type="text" class="code-input" maxlength="1" inputmode="numeric" required>
                <input type="text" class="code-input" maxlength="1" inputmode="numeric" required>
                <input type="text" class="code-input" maxlength="1" inputmode="numeric" required>
            </div>

            <button type="submit" class="btn btn-continue w-100 fw-bold mb-4 shadow">{{ trans('verify.button') }}</button>

            <div class="text-center fs-6 text-muted">
                {{ trans('verify.code') }} <a href="#" class="text-purple">{{ trans('verify.resend') }}</a>
            </div>

        </form>
    </div>

{% endblock %}
{% block footer %}{% endblock %}
{% block scripts %}
    <script>
        const inputs = document.querySelectorAll('.code-input');
        inputs.forEach((input, index) => {
            input.addEventListener('input', (e) => {
                if (e.target.value.length === 1) {
                    if (inputs[index + 1]) inputs[index + 1].focus();
                }
            });
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !e.target.value) {
                    if (inputs[index - 1]) inputs[index - 1].focus();
                }
            });
        });
    </script>
{% endblock %}
