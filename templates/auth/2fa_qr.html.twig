{% extends "layout.html.twig" %}
{% block title %}{{ trans('app.title') }} - {{ trans('2fa.setup_subheading') }}{% endblock %}
{% block navbar %}{% endblock %}
{% block head %}
<style>
    body {
        background: linear-gradient(135deg, #a060a8 0%, #4a215d 100%);
        min-height: 100vh;
    }

    main {
        align-self: stretch;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .setup-container {
        max-width: 500px;
        width: 100%;
    }

    .logo-circle {
        width: 60px;
        height: 60px;
        background-color: white;
        color: #7b2cbf;
        font-size: 30px;
    }

    .step {
        display: flex;
        align-items: flex-start;
        gap: 0.85rem;
    }

    .step-number {
        flex-shrink: 0;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #5E246E;
        color: white;
        font-size: 0.8rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-top: 1px;
    }

    .step-text {
        font-size: 0.95rem;
        color: #444;
        line-height: 1.5;
    }

    .step-text strong { color: #2d1b3d; }

    #qr-image {
        width: 200px;
        height: 200px;
        border-radius: 0.75rem;
        padding: 10px;
        background: white;
        box-shadow: 0 4px 20px rgba(94, 36, 110, 0.15);
        display: block;
    }

    .secret-key-box {
        background: #f8f2fc;
        border: 1px solid #d0aee8;
        border-radius: 0.6rem;
        padding: 0.6rem 1rem;
        font-family: 'Courier New', monospace;
        font-size: 0.95rem;
        letter-spacing: 0.12em;
        color: #5E246E;
        font-weight: 600;
        text-align: center;
        cursor: pointer;
        transition: background 0.2s;
        width: 100%;
        word-break: break-all;
    }

    .secret-key-box:hover { background: #efe0f8; }

    .copy-hint {
        display: none;
        font-size: 0.75rem;
        color: #9b59b6;
        margin-top: 0.25rem;
        text-align: center;
    }

    .copy-hint.visible { display: block; }

    .or-divider {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: #aaa;
        font-size: 0.8rem;
        width: 100%;
    }

    .or-divider::before,
    .or-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #e0d0ea;
    }

    .btn-primary-tm {
        background-color: #5E246E;
        color: white;
        border: none;
        padding: 0.8rem;
        font-size: 1.05rem;
        font-weight: 600;
        border-radius: 0.5rem;
        transition: background-color 0.25s ease;
        width: 100%;
    }

    .btn-primary-tm:hover {
        background-color: #371840;
        color: white;
    }

    .otp-input {
        letter-spacing: 0.3em;
        text-align: center;
        font-size: 1.4rem;
        font-weight: 600;
        padding: 0.7rem 1rem;
        border: 1.5px solid #d0aee8;
        border-radius: 0.5rem;
        color: #2d1b3d;
    }

    .otp-input:focus {
        border-color: #7b2cbf;
        outline: none;
        box-shadow: 0 0 0 3px rgba(123, 44, 191, 0.15);
    }

    .alert-error-tm {
        background: #fdecea;
        border: 1px solid #ef9a9a;
        color: #c62828;
        border-radius: 0.5rem;
        padding: 0.75rem 1rem;
        font-size: 0.9rem;
    }
</style>
{% endblock %}
{% block content %}

    <div class="text-center text-white mb-4">
        <div class="logo-circle rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow">
            <i class="bi bi-ticket-perforated-fill"></i>
        </div>
        <h1 class="fw-bold display-5">{{ trans('2fa.setup_heading') }}</h1>
        <p class="fs-5 opacity-75">{{ trans('2fa.setup_subheading') }}</p>
    </div>

    <div class="card setup-container shadow-lg border-0 rounded-4 p-4 p-sm-5">

        <div class="d-flex flex-column gap-3 mb-4">
            <div class="step">
                <div class="step-number">1</div>
                <div class="step-text">
                    <strong>{{ trans('2fa.step1_title') }}</strong> {{ trans('2fa.step1_apps') }}
                </div>
            </div>
            <div class="step">
                <div class="step-number">2</div>
                <div class="step-text">
                    <strong>{{ trans('2fa.step2_title') }}</strong> {{ trans('2fa.step2_desc') }}
                </div>
            </div>
            <div class="step">
                <div class="step-number">3</div>
                <div class="step-text">
                    <strong>{{ trans('2fa.step3_title') }}</strong> {{ trans('2fa.step3_desc') }}
                </div>
            </div>
        </div>

        <hr class="mb-4">

        {% if error %}
        <div class="alert-error-tm mb-4">
            <i class="bi bi-x-circle-fill me-2"></i>{{ error }}
        </div>
        {% endif %}

        <div class="d-flex justify-content-center mb-3">
            <img id="qr-image"
                 src="{{ qr_code }}"
                 alt="Scan this QR code with your authenticator app">
        </div>

        <div class="or-divider my-3">{{ trans('2fa.cant_scan') }}</div>

        <div class="secret-key-box mb-1" onclick="copySecret()" title="{{ trans('2fa.click_copy') }}">
            <i class="bi bi-key me-1"></i>
            <span id="secret-key-text">{{ secret }}</span>
        </div>
        <div id="copy-hint" class="copy-hint">{{ trans('2fa.copied') }}</div>

        <hr class="mt-4 mb-4">

        <form action="{{ base_path }}/2fa/setup" method="POST">
            {{ csrf_field() }}
            <div class="mb-3">
                <label class="form-label fw-bold" for="otp-field">{{ trans('2fa.code_label') }}</label>
                <input id="otp-field"
                       type="text"
                       name="otp"
                       inputmode="numeric"
                       pattern="[0-9]*"
                       maxlength="6"
                       class="form-control otp-input"
                       placeholder="{{ trans('2fa.code_placeholder') }}"
                       autocomplete="one-time-code"
                       required>
            </div>

            <button type="submit" class="btn btn-primary-tm">
                {{ trans('2fa.setup_button') }}
            </button>

        </form>

    </div>

    <div class="text-center mt-4 text-white-50 px-4" style="font-size: 0.85rem; max-width: 500px;">
        {{ trans('2fa.safety_note') }}
    </div>

{% endblock %}
{% block footer %}{% endblock %}
{% block scripts %}
    <script>
        function copySecret() {
            const text = document.getElementById('secret-key-text').textContent.trim();
            navigator.clipboard.writeText(text).then(() => {
                const hint = document.getElementById('copy-hint');
                hint.classList.add('visible');
                setTimeout(() => hint.classList.remove('visible'), 2000);
            });
        }
    </script>
{% endblock %}
