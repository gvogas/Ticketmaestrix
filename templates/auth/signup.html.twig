{% extends "layout.html.twig" %}
{% block title %}{{ trans('app.title') }} - {{ trans('app.signup') }}{% endblock %}
{% block navbar %}{% endblock %}
{% block head %}
<style>
    body {
        background: linear-gradient(135deg, #a060a8 0%, #4a215d 100%);
        min-height: 100vh;
        margin: 0;
    }

    main {
        align-self: stretch;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .signup-container {
        max-width: 500px;
        width: 100%;
    }

    .logo-circle {
        width: 60px;
        height: 60px;
        background-color: white;
        color: #7b2cbf;
        font-size: 30px;
    }

    .btn-signup {
        background-color: #5E246E;
        color: white !important;
        border: none;
        padding: 0.8rem;
        font-size: 1.1rem;
        transition: background-color 0.3s ease;
    }

    .btn-signup:hover {
        background-color: #371840;
        color: white !important;
    }

.text-purple {
        color: #7b2cbf;
        text-decoration: none;
        font-weight: 600;
    }

    .form-control, .btn, .input-group-text {
        padding: 0.8rem 1rem;
        font-size: 1.1rem;
    }
</style>
{% endblock %}
{% block content %}

    <div class="text-center text-white mb-4">
        <div class="logo-circle rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow">
            <i class="bi bi-ticket-perforated-fill"></i>
        </div>
        <h1 class="fw-bold display-5">{{ trans('signup.header') }}</h1>
        <p class="fs-5 opacity-75">{{ trans('signup.subheader') }}</p>
    </div>

    <div class="card signup-container shadow-lg border-0 rounded-4 p-5">
        <form action="{{ base_path }}/signup" method="POST">
            {{ csrf_field() }}

            <div class="mb-4">
                <label class="form-label fw-bold">{{ trans('signup.name') }}</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-person"></i></span>
                    <input type="text" name="fullname" required
                           class="form-control border-start-0{{ errors.fullname is defined ? ' is-invalid' : '' }}"
                            placeholder="{{ trans('ph.full_name') }}"
                            value="{{ input.fullname ?? '' }}">
                    {% if errors.fullname is defined %}
                        <div class="invalid-feedback">{{ errors.fullname | first }}</div>
                    {% endif %}
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">{{ trans('signup.email') }}</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-envelope"></i></span>
                    <input type="email" name="email" required
                           class="form-control border-start-0{{ errors.email is defined ? ' is-invalid' : '' }}"
                            placeholder="{{ trans('ph.email') }}"
                            value="{{ input.email ?? '' }}">
                    {% if errors.email is defined %}
                        <div class="invalid-feedback">{{ errors.email | first }}</div>
                    {% endif %}
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">{{ trans('signup.password') }}</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-lock"></i></span>
                    <input type="password" name="password" required minlength="8"
                           class="form-control border-start-0{{ errors.password is defined ? ' is-invalid' : '' }}"
                            placeholder="{{ trans('ph.password') }}">
                    {% if errors.password is defined %}
                        <div class="invalid-feedback">{{ errors.password | first }}</div>
                    {% endif %}
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">{{ trans('signup.confirm') }}</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-lock-fill"></i></span>
                    <input type="password" name="password2" required minlength="8"
                           class="form-control border-start-0{{ errors.password2 is defined ? ' is-invalid' : '' }}"
                           placeholder="{{ trans('ph.password') }}">
                    {% if errors.password2 is defined %}
                        <div class="invalid-feedback">{{ errors.password2 | first }}</div>
                    {% endif %}
                </div>
            </div>

            <div class="mb-4 fs-6">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="terms" name="terms" required>
                    <label class="form-check-label text-muted" for="terms">
                        {{ trans('signup.agree') }} <a href="#" class="text-purple">{{ trans('signup.terms') }}</a> {{ trans('signup.and') }} <a href="#" class="text-purple">{{ trans('signup.privacy') }}</a>
                    </label>
                </div>
            </div>

            <button type="submit" class="btn btn-signup w-100 fw-bold mb-4 shadow">{{ trans('signup.button') }}</button>

            <div class="text-center fs-6">
                {{ trans('signup.account') }} <a href="{{ base_path }}/login" class="text-purple">{{ trans('signup.login') }}</a>
            </div>

        </form>
    </div>

{% endblock %}
{% block footer %}{% endblock %}
