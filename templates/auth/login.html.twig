<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TicketMaestrix - Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="{{ base_path }}/css/forms.css">

    <style>
        body {
            background: linear-gradient(135deg, #a060a8 0%, #4a215d 100%);
            min-height: 100vh;
        }
        
        .login-container {
            max-width: 500px; 
            width: 100%;
        }

        .logo-circle {
            width: 60px;
            height: 60px;
            background-color: white;
            color: #7b2cbf;
            font-size: 30px;
        }

        .btn-signin {
            background-color: #5E246E;
            color: white !important;
            border: none;
            padding: 0.8rem;
            font-size: 1.1rem;
            transition: background-color 0.3s ease;
        }

        .btn-signin:hover {
            background-color: #371840;
            color: white !important;
        }

        .bi-google { color: #DB4437; } 
        .bi-facebook { color: #1877F2; } 

        .text-purple {
            color: #7b2cbf;
            text-decoration: none;
            font-weight: 600;
        }

        .form-control-lg {
            font-size: 1.05rem;
        }

        .form-control, .btn, .input-group-text {
            padding: 0.8rem 1rem;
            font-size: 1.1rem;
        }

        .text-purple {
            color: #7b2cbf;
            text-decoration: none;
            font-weight: 600;
        }
    </style>
</head>
<body class="d-flex flex-column align-items-center justify-content-center p-3">

    <div class="text-center text-white mb-4">
        <div class="logo-circle rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow">
            <i class="bi bi-ticket-perforated-fill"></i>
        </div>
        <h1 class="fw-bold display-5">Welcome Back</h1>
        <p class="fs-5 opacity-75">Sign in to continue to TicketMaestrix</p>
    </div>

    <div class="card login-container shadow-lg border-0 rounded-4 p-5">
        <form action="{{ base_path }}/login" method="POST">

            {% if error %}
            <div class="alert alert-danger mb-4">{{ error }}</div>
            {% endif %}

            <div class="mb-4">
                <label class="form-label fw-bold">Email Address</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-envelope"></i></span>
                    <input type="email" name="email" required
                           class="form-control border-start-0"
                           placeholder="john@example.com">
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Password</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-lock"></i></span>
                    <input type="password" name="password" required
                           class="form-control border-start-0"
                           placeholder="••••••••">
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 fs-6">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="rememberMe">
                    <label class="form-check-label" for="rememberMe">Remember me</label>
                </div>
                <a href="{{ base_path }}/forgotpassword" class="text-purple">Forgot password?</a>
            </div>

            <button type="submit" class="btn btn-signin w-100 fw-bold mb-4 shadow">Sign In</button>

            <div class="text-center fs-6">
                Don't have an account? <a href="{{ base_path }}/signup" class="text-purple">Sign up</a>
            </div>
            
        </form>
    </div>

    <div class="text-center mt-5 text-white-50 px-4" style="font-size: 0.9rem; max-width: 500px;">
        By continuing, you agree to TicketMaestrix's 
        <a href="#" class="text-white text-decoration-none border-bottom">Terms of Service</a> and 
        <a href="#" class="text-white text-decoration-none border-bottom">Privacy Policy</a>
    </div>

</body>
</html>