{% extends "layout.html.twig" %}
{% block title %}{{ trans('app.title') }} - {{ trans('app.login') }}{% endblock %}
{% block navbar %}{% endblock %}
{% block head %}
<style>
    body {
        background: linear-gradient(135deg, #a060a8 0%, #4a215d 100%);
        min-height: 100vh;
    }

    main {
        align-self: stretch;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .login-container {
        max-width: 500px;
        width: 100%;
    }

    .login-logo-badge {
        width: 118px;
        height: 76px;
        background-color: white;
        border-radius: 18px;
        padding: 8px 12px;
    }

    .login-logo {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .btn-signin {
        background-color: #5E246E;
        color: white !important;
        border: none;
        padding: 0.8rem;
        font-size: 1.1rem;
        transition: background-color 0.3s ease;
    }

    .btn-signin:hover {
        background-color: #371840;
        color: white !important;
    }

.text-purple {
        color: #7b2cbf;
        text-decoration: none;
        font-weight: 600;
    }

    .form-control-lg {
        font-size: 1.05rem;
    }

    .form-control, .btn, .input-group-text {
        padding: 0.8rem 1rem;
        font-size: 1.1rem;
    }
</style>
{% endblock %}
{% block content %}

    <div class="text-center text-white mb-4">
        <div class="login-logo-badge d-inline-flex justify-content-center align-items-center mb-3 shadow">
            <img class="login-logo" src="{{ base_path }}/assets/img/ticketmaestrix-logo.png" alt="{{ trans('app.title') }}">
        </div>
        <h1 class="fw-bold display-5">{{ trans('login.header') }}</h1>
        <p class="fs-5 opacity-75">{{ trans('login.subheader') }}</p>
    </div>

    <div class="card login-container shadow-lg border-0 rounded-4 p-5">
        <form action="{{ base_path }}/login" method="POST">

            {% if error %}
            <div class="alert alert-danger mb-4">{{ error }}</div>
            {% endif %}

            <div class="mb-4">
                <label class="form-label fw-bold">{{ trans('login.email') }}</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-envelope"></i></span>
                    <input type="email" name="email" required
                           class="form-control border-start-0"
                           placeholder="{{ trans('ph.email') }}">
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">{{ trans('login.password') }}</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-lock"></i></span>
                    <input type="password" name="password" required
                           class="form-control border-start-0"
                           placeholder="{{ trans('ph.password') }}">
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 fs-6">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="rememberMe" name="remember_me" value="1">
                    <label class="form-check-label" for="rememberMe">{{ trans('login.remember') }}</label>
                </div>
                <a href="{{ base_path }}/forgotpassword" class="text-purple">{{ trans('login.forgot') }}</a>
            </div>

            <button type="submit" class="btn btn-signin w-100 fw-bold mb-4 shadow">{{ trans('login.button') }}</button>

            <div class="text-center fs-6">
                {{ trans('login.account') }} <a href="{{ base_path }}/signup" class="text-purple">{{ trans('login.signup') }}</a>
            </div>

        </form>
    </div>

    <div class="text-center mt-5 text-white-50 px-4" style="font-size: 0.9rem; max-width: 500px;">
        {{ trans('login.agree') }}
        <a href="#" class="text-white text-decoration-none border-bottom">{{ trans('login.terms') }}</a> {{ trans('login.and') }}
        <a href="#" class="text-white text-decoration-none border-bottom">{{ trans('login.privacy') }}</a>
    </div>

{% endblock %}
{% block footer %}{% endblock %}
