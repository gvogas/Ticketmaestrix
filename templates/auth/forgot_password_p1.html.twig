<!DOCTYPE html>
<html lang="{{ current_locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ trans('app.title') }} - {{ trans('forgot.header') }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body {
            background: linear-gradient(135deg, #a060a8 0%, #4a215d 100%);
            min-height: 100vh;
            margin: 0;
        }

        .forgot-container {
            max-width: 500px;
            width: 100%;
        }

        .logo-circle {
            width: 60px;
            height: 60px;
            background-color: white;
            color: #7b2cbf;
            font-size: 30px;
        }

        .btn-submit {
            background-color: #5E246E;
            color: white !important;
            border: none;
            padding: 0.8rem;
            font-size: 1.1rem;
            transition: background-color 0.3s ease;
        }

        .btn-submit:hover {
            background-color: #371840;
            color: white !important;
        }

        .text-purple {
            color: #7b2cbf;
            text-decoration: none;
            font-weight: 600;
        }

        .form-control, .btn, .input-group-text {
            padding: 0.8rem 1rem;
            font-size: 1.1rem;
        }
    </style>
</head>
<body class="d-flex flex-column align-items-center justify-content-center p-3">

    <div class="text-center text-white mb-4">
        <div class="logo-circle rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <h1 class="fw-bold display-5">{{ trans('forgot.header') }}</h1>
        <p class="fs-5 opacity-75">{{ trans('forgot.subheader') }}</p>
    </div>

    <div class="card forgot-container shadow-lg border-0 rounded-4 p-5">
        <form action="/forgotpassword" method="POST">

            <div class="mb-4">
                <label class="form-label fw-bold">{{ trans('forgot.email') }}</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-envelope"></i></span>
                    <input type="email" name="email" class="form-control border-start-0" placeholder="{{ trans('ph.email') }}" required>
                </div>
            </div>

            <button type="submit" class="btn btn-submit w-100 fw-bold mb-4 shadow">{{ trans('forgot.button') }}</button>

            <div class="text-center fs-6">
                {{ trans('forgot.remember') }} <a href="{{ base_path }}/login" class="text-purple">{{ trans('forgot.back') }}</a>
            </div>

        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
