{% extends "layout.html.twig" %}
{% block title %}{{ trans('app.title') }} - {{ trans('newpass.header') }}{% endblock %}
{% block navbar %}{% endblock %}
{% block head %}
<style>
    body {
        background: linear-gradient(135deg, #a060a8 0%, #4a215d 100%);
        min-height: 100vh;
        margin: 0;
    }

    main {
        align-self: stretch;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .reset-container {
        max-width: 500px;
        width: 100%;
    }

    .logo-circle {
        width: 60px;
        height: 60px;
        background-color: white;
        color: #7b2cbf;
        font-size: 30px;
    }

    .btn-reset {
        background-color: #5E246E;
        color: white !important;
        border: none;
        padding: 0.8rem;
        font-size: 1.1rem;
        transition: background-color 0.3s ease;
    }

    .btn-reset:hover {
        background-color: #371840;
        color: white !important;
    }

    .form-control, .btn, .input-group-text {
        padding: 0.8rem 1rem;
        font-size: 1.1rem;
    }

    .input-group-text {
        background-color: transparent;
        color: #6c757d;
    }
</style>
{% endblock %}
{% block content %}

    <div class="text-center text-white mb-4">
        <div class="logo-circle rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow">
            <i class="bi bi-key-fill"></i>
        </div>
        <h1 class="fw-bold display-5">{{ trans('newpass.header') }}</h1>
        <p class="fs-5 opacity-75">{{ trans('newpass.subheader') }}</p>
    </div>

    <div class="card reset-container shadow-lg border-0 rounded-4 p-5">
        <form action="/forgotpassword" method="POST">

            <div class="mb-4">
                <label class="form-label fw-bold small text-uppercase text-muted">{{ trans('newpass.password') }}</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text border-end-0"><i class="bi bi-lock"></i></span>
                    <input type="password" id="password" name="password" class="form-control border-start-0" placeholder="{{ trans('ph.password') }}" required>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold small text-uppercase text-muted">{{ trans('newpass.confirm') }}</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text border-end-0"><i class="bi bi-lock-fill"></i></span>
                    <input type="password" id="password2" name="password2" class="form-control border-start-0" placeholder="{{ trans('ph.password') }}" required>
                </div>
            </div>

            <button type="submit" class="btn btn-reset w-100 fw-bold mb-3 shadow">{{ trans('newpass.button') }}</button>

        </form>
    </div>

{% endblock %}
{% block footer %}{% endblock %}
